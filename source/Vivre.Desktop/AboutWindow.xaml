<ui:FluentWindow x:Class="Vivre.Desktop.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="About Vivre"
        Height="720" Width="600"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!-- Layered: blurred hero image, a dark gradient scrim, then the content (white text). -->
    <Grid>
        <!-- Negative margin pushes the blurred edges past the window clip. -->
        <Image Source="pack://application:,,,/Assets/AboutBackground.png"
               Stretch="UniformToFill" Margin="-12">
            <Image.Effect>
                <BlurEffect Radius="6" KernelType="Gaussian" />
            </Image.Effect>
        </Image>

        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="#40000000" />
                    <GradientStop Offset="0.45" Color="#59000000" />
                    <GradientStop Offset="1.0" Color="#A6000000" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Content. Default text is near-white; headings/captions override below. -->
        <Grid TextElement.Foreground="#F2FFFFFF">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="About Vivre">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.png" Width="18" Height="18" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>

            <!-- Header: logo + name + tagline (text set from AppInfo in code-behind) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,8,20,8" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/Assets/AppIcon.png" Width="52" Height="52" VerticalAlignment="Center" />
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="NameText" FontSize="30" FontWeight="Bold" Foreground="#FFFFFFFF" Text="Vivre" />
                    <TextBlock x:Name="TaglineText" FontSize="13" Foreground="#CCFFFFFF" Text="The heartbeat of your fleet." />
                    <TextBlock x:Name="EditionText" FontSize="11" Foreground="#99FFFFFF" Text=".NET 10 / WPF" />
                </StackPanel>
            </StackPanel>

            <!-- Frosted card holding the prose; the image breathes around it. -->
            <Border Grid.Row="2" Margin="16,4,16,12"
                    Background="#8C0B0E12" CornerRadius="10"
                    BorderBrush="#26FFFFFF" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,14,18,14">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="Why Vivre?" Margin="0,2,0,0" />
                        <TextBlock FontSize="13" FontStyle="Italic" Foreground="#CCFFFFFF" TextWrapping="Wrap"
                                   Text="A short story about a tool name, with detours into French verbs and pirate lore." Margin="0,2,0,12" />

                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="The literal meaning" Margin="0,4,0,2" />
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Vivre is French. Verb. To live. Root of survive, vivid, vivacious. Five letters, easy to type, no collisions in the IT-tooling namespace — there's no other Windows admin tool called Vivre." />

                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="The reference (for the One Piece nerds clicking this)" Margin="0,4,0,2" TextWrapping="Wrap" />
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="In One Piece, a Vivre Card is a slip of paper made from a person's fingernail that tracks their life force." />
                        <StackPanel Margin="8,0,0,6">
                            <TextBlock TextWrapping="Wrap" Text="•  It points toward where they are — a built-in locator beacon." />
                            <TextBlock TextWrapping="Wrap" Text="•  It singes at the edges when they're hurt." />
                            <TextBlock TextWrapping="Wrap" Text="•  It burns away as they're weakened." />
                            <TextBlock TextWrapping="Wrap" Text="•  It turns to ash when they die." />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="You carry the cards of your crew so you always know who's alive, where, and how they're holding up. Ace gives one to Luffy on the way out of Alabasta. The Straw Hats are scattered across two seas with cards in their pockets." />
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="That is literally what this tool does. Every row in the grid is a Vivre Card for one machine in the fleet." />

                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="Every signal maps cleanly" Margin="0,4,0,4" />
                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Padding="2" Margin="0,0,0,12" Background="#33000000">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" FontSize="11" Foreground="#B3FFFFFF" Padding="6,4" Text="What the tool tracks" />
                                <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" Foreground="#B3FFFFFF" Padding="6,4" Text="Vivre Card analog" />

                                <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Online — responds to ICMP or WinRM" />
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card whole and warm" />
                                <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Offline — unreachable" />
                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card going dark" />
                                <TextBlock Grid.Row="3" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Reboot pending" />
                                <TextBlock Grid.Row="3" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card singed at the edge — bearer is wounded" />
                                <TextBlock Grid.Row="4" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Updates missing" />
                                <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card shrinking — bearer's strength fading" />
                                <TextBlock Grid.Row="5" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Install running" />
                                <TextBlock Grid.Row="5" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card actively redrawing — bearer is recovering" />
                                <TextBlock Grid.Row="6" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Just rebooted" />
                                <TextBlock Grid.Row="6" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Card refreshed — bearer recovered" />
                                <TextBlock Grid.Row="7" Grid.Column="0" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="Last reboot &quot;4h&quot;" />
                                <TextBlock Grid.Row="7" Grid.Column="1" FontSize="12" Padding="6,3" TextWrapping="Wrap" Text="How long since the bearer was last seen healthy" />
                            </Grid>
                        </Border>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="The features were already there — the name just gave them a vocabulary." />

                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="Watch the cards" Margin="0,4,0,2" />
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                   Text="Vivre is the heartbeat of your fleet. Every row is alive or dying, here or there, healthy or wounded — keep their cards in your pocket and you always know who needs you." />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="3" Background="#A60B0E12" BorderBrush="#26FFFFFF" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="#F2FFFFFF" Text="Built by Shaun Bridges" />
                        <TextBlock FontSize="11" Foreground="#99FFFFFF" Text="One Piece is a manga by Eiichiro Oda — go read it." />
                    </StackPanel>
                    <ui:Button Grid.Column="1" Appearance="Primary" Content="Close" Click="OnClose" IsDefault="True" IsCancel="True" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
