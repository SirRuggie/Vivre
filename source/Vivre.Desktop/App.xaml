<Application x:Class="Vivre.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Vivre.Desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI theme + control styles. Theme is the initial app theme;
                     it is switched at runtime via ApplicationThemeManager. -->
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- M3: standard horizontal inset for dialog content and footer rows. -->
            <Thickness x:Key="DialogContentMargin">24,8,24,0</Thickness>

            <!-- M7: three-level type ramp for secondary labels. -->
            <Style x:Key="CaptionText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            </Style>
            <Style x:Key="LabelText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            </Style>
            <Style x:Key="BodyText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
            </Style>

            <!-- M5: shared Fluent tab style — browser/Windows-Terminal-style document tabs.
                 Active tab: content-surface background + visible 3px accent top bar. No bottom border so
                 the active tab merges visually with the content area. Inactive tabs: subtle muted fill,
                 secondary text. Hover: gentle highlight. M26: focus ring on keyboard focus.

                 The accent bar is a separate Border (x:Name="AccentBar") positioned at the very top of a
                 root Grid. It is NOT inside a CornerRadius Border — that caused WPF's curved border
                 renderer to draw it only at the corners. Being an independent child of the root Grid it
                 renders its full width correctly. It is Transparent on inactive tabs and accent-colored
                 when IsSelected=True. The tab fill/stroke shape uses ClipToBounds=False so the AccentBar
                 can overlap the top edge. -->
            <Style x:Key="FluentTabItemStyle" TargetType="TabItem">
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="Margin" Value="0,0,2,0" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <!-- Tab fill + stroke shape. The content sits here with its padding. -->
                                <Border x:Name="Bd" CornerRadius="6,6,0,0"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1,1,1,0">
                                    <!-- M26: accent focus ring drawn around the header content. -->
                                    <Border x:Name="FocusRing" CornerRadius="3" BorderThickness="2"
                                            BorderBrush="Transparent" IsHitTestVisible="False">
                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                                    </Border>
                                </Border>
                                <!-- Accent bar: an independent element in the same Grid, painted OVER the
                                     tab body. VerticalAlignment=Top + Height=3 pins it to the top edge.
                                     Margin=1,1,1,0 insets it just inside the side borders so it doesn't
                                     overdraw the corner curves. Transparent when inactive; accent when
                                     IsSelected. CornerRadius on a Border gives it softly-rounded ends. -->
                                <Border x:Name="AccentBar"
                                        Height="3" VerticalAlignment="Top"
                                        CornerRadius="5,5,0,0"
                                        Margin="1,1,1,0"
                                        Background="Transparent"
                                        IsHitTestVisible="False" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <!-- Hover (inactive only): slightly brighter fill + primary text. -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </MultiTrigger>
                                <!-- Active: content-area background + accent top bar. -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                    <Setter TargetName="AccentBar" Property="Background"
                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <!-- M26: show accent focus ring on keyboard focus. -->
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="FocusRing" Property="BorderBrush"
                                            Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- M5: sub-tab variant (reduced padding for the inner Applicable/Installed tabs). -->
            <Style x:Key="FluentSubTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource FluentTabItemStyle}">
                <Setter Property="Padding" Value="10,4" />
            </Style>

            <!-- M13: reusable empty-state panel — centered icon + title + optional subtitle.
                 Consumers embed an EmptyStatePanel with Tag="Icon|Title|Subtitle" or build
                 inline; the shared container style keeps padding/alignment consistent.
                 Non-interactive: IsHitTestVisible=False so overlaid grids still receive input. -->
            <Style x:Key="EmptyStatePanel" TargetType="StackPanel">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Orientation" Value="Vertical" />
                <Setter Property="IsHitTestVisible" Value="False" />
            </Style>

            <!-- M13: title line for the empty-state panel. -->
            <Style x:Key="EmptyStateTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,8,0,0" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- M13: subtitle / hint line for the empty-state panel. -->
            <Style x:Key="EmptyStateSubtitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- M27: thin overlay scrollbar — 6px track at rest, thumb brightens on hover/drag.
                 Applies to ALL native ScrollBar controls (DataGrid, ScrollViewer, TextBox).
                 Separate vertical and horizontal templates avoid layout-direction conflicts. -->

            <!-- Shared thumb sub-style used by both orientations. -->
            <Style x:Key="OverlayScrollThumbStyle" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="ThumbBd" CornerRadius="3" Margin="1"
                                    Background="{DynamicResource TextFillColorTertiaryBrush}" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbBd" Property="Background"
                                            Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbBd" Property="Background"
                                            Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Template">
                    <Setter.Value>
                        <!-- Vertical scrollbar (default) -->
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid x:Name="Root" Width="8">
                                <Border x:Name="TrackBg" Background="Transparent" CornerRadius="4" />
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Opacity="0" IsEnabled="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Rectangle Fill="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Opacity="0" IsEnabled="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Rectangle Fill="Transparent" />
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource OverlayScrollThumbStyle}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter TargetName="Root" Property="Width" Value="Auto" />
                                    <Setter TargetName="Root" Property="Height" Value="8" />
                                    <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
