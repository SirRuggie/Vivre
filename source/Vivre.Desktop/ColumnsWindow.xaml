<ui:FluentWindow x:Class="Vivre.Desktop.ColumnsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        mc:Ignorable="d"
        Title="Columns"
        Height="620" Width="560"
        MinHeight="500" MinWidth="480"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Columns" Icon="{ui:SymbolIcon Settings24}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,0">
            <StackPanel>
                <ui:TextBlock x:Name="Intro" Appearance="Secondary" TextWrapping="Wrap" Margin="0,0,0,16" />

                <!-- Show/hide the built-in columns -->
                <ui:TextBlock Text="Show columns" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ui:TextBlock Appearance="Secondary" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6"
                              Text="Untick a built-in column to hide it (Name always stays). Saved across launches and tabs." />
                <StackPanel x:Name="BuiltinList" Margin="0,0,0,16" />

                <!-- Existing custom columns -->
                <ui:TextBlock Text="Custom columns" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ui:TextBlock Appearance="Secondary" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6"
                              Text="Each runs a PowerShell one-liner on every machine; its output fills the cell. Click Refresh values to re-run." />
                <ItemsControl x:Name="CustomList" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                <ui:Button Grid.Column="1" Content="Remove" Tag="{Binding Name}" Click="OnRemoveColumn" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ui:TextBlock x:Name="NoCustomHint" Appearance="Secondary" FontSize="12" Margin="0,0,0,8"
                              Text="(none yet — add one below)" />

                <!-- Add a predefined column -->
                <ui:TextBlock Text="Add a predefined column" FontWeight="SemiBold" Margin="0,12,0,4" />
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="GalleryBox" Grid.Column="0" VerticalAlignment="Center" DisplayMemberPath="Name" />
                    <ui:Button Grid.Column="1" Margin="8,0,0,0" Content="Add" Click="OnAddFromGallery" />
                </Grid>

                <!-- Add your own -->
                <ui:TextBlock Text="Add your own" FontWeight="SemiBold" Margin="0,16,0,4" />
                <ui:TextBox x:Name="NameBox" Margin="0,0,0,6" PlaceholderText="Column name (e.g. Serial)" />
                <ui:TextBox x:Name="ScriptBox" MinHeight="56" AcceptsReturn="True" TextWrapping="Wrap"
                            FontFamily="Cascadia Code, Consolas, monospace"
                            PlaceholderText="PowerShell one-liner, e.g. (Get-CimInstance Win32_BIOS).SerialNumber" />
                <ui:TextBlock Appearance="Secondary" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"
                              Text="Runs on each machine; whatever it prints becomes the cell. Avoid [ ] and , in the name." />
                <ui:Button Content="Add column" Margin="0,8,0,0" Click="OnAddCustom" />

                <ui:TextBlock x:Name="StatusText" Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                              TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,16">
            <ui:Button Content="Refresh values" Icon="{ui:SymbolIcon ArrowSync24}" Click="OnRefresh" />
            <ui:Button Margin="8,0,0,0" Content="Close" Click="OnClose" IsCancel="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
