<ui:FluentWindow x:Class="Vivre.Desktop.ComputerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        mc:Ignorable="d"
        Title="Machine details"
        Height="760" Width="820" MinHeight="600" MinWidth="680"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <local:StatusBrushConverter x:Key="StatusBrush" />
        <local:StatusSymbolConverter x:Key="StatusSymbol" />
        <local:BoolStateTextConverter x:Key="YesNo" />
        <local:PhaseChipLabelConverter x:Key="PhaseLabel" />
        <local:LogSeverityBrushConverter x:Key="SeverityBrush" />
        <local:LogSeveritySymbolConverter x:Key="SeveritySymbol" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:NotNullToVisibilityConverter x:Key="NotNullToVis" />
        <local:NonZeroToVisibilityConverter x:Key="NonZeroToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- One light card per Vitals section, so groups read as distinct blocks instead of one long,
             clumped list. ~12px between cards; the card's own padding replaces the old per-header top margin. -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Machine details" />

        <!-- Header card: identity + current update state. -->
        <Border Grid.Row="1" Margin="16,4,16,8" Padding="14,12" CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"
                                   Symbol="{Binding Computer.IsOnline, Converter={StaticResource StatusSymbol}}"
                                   Foreground="{Binding Computer.IsOnline, Converter={StaticResource StatusBrush}}"
                                   ToolTip="{Binding Computer.LastStatus}" />
                    <ui:TextBlock Text="{Binding Computer.Name}" FontTypography="Subtitle" VerticalAlignment="Center" />
                    <Border CornerRadius="8" Padding="8,1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <!-- Available = call-to-action (updates ready to install): accent fill so it
                                         pops past the quiet working/idle tints. -->
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                    </DataTrigger>
                                    <!-- Couldn't confirm/rescan: neutral-grey pill matching the grid, never green. -->
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Unverified">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Computer.PatchState, Converter={StaticResource PhaseLabel}}"
                                   FontSize="11" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Unverified">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="{Binding Computer.UpdateMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Computer.RebootMessage}" />

                <ProgressBar Margin="0,8,0,0" Height="6" Minimum="0" Maximum="100"
                             Value="{Binding Computer.UpdateProgress, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,2" Text="OS" />
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,2" TextWrapping="Wrap"
                                  Text="{Binding Computer.OperatingSystem, TargetNullValue='—'}" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,2" Text="Reboot pending" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,2"
                                  Text="{Binding Computer.RebootRequired, Converter={StaticResource YesNo}}" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,0" Text="Scheduled" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="1"
                                  Text="{Binding Computer.ScheduledNextRun, StringFormat=g, TargetNullValue='—'}" />
                </Grid>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Margin="16,0,16,16">
            <TabItem Header="Vitals">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,12,12,12">
                        <!-- Score + band + when it was read.
                             DataTriggers + DynamicResource so colors re-resolve on theme switch. -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border CornerRadius="8" Padding="12,4" MinWidth="40" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Healthy">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Warning">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Critical">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Computer.VitalityScore, TargetNullValue=—}"
                                           FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Healthy">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Critical">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <ui:TextBlock Text="{Binding Computer.VitalityBand, TargetNullValue='Not checked yet'}" FontTypography="BodyStrong" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="{Binding Computer.VitalsCheckedAt, StringFormat='Checked {0:g}', TargetNullValue='Vitals haven\'t been read for this machine yet.'}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Check Vitals button — always visible so the user can run or re-run vitals from
                             the detail window without going back to the fleet grid. Prominent (Primary) when
                             vitals are absent; available as a small re-check button once they're populated.
                             Disabled while a fleet sweep already holds this machine OR while the command
                             itself is running (AsyncRelayCommand default). -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                            <ui:Button Command="{Binding CheckVitalsCommand}"
                                       ToolTipService.ShowOnDisabled="True">
                                <ui:Button.ToolTip>
                                    <ToolTip Content="Busy — an operation is already running on this machine." />
                                </ui:Button.ToolTip>
                                <ui:Button.Style>
                                    <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <!-- Default (vitals present): small secondary button for re-checks. -->
                                        <Setter Property="Appearance" Value="Secondary" />
                                        <Setter Property="Padding" Value="10,4" />
                                        <Style.Triggers>
                                            <!-- No vitals yet: accent primary so it catches the eye. -->
                                            <DataTrigger Binding="{Binding Computer.VitalsCheckedAt}" Value="{x:Null}">
                                                <Setter Property="Appearance" Value="Primary" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <ui:Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:ProgressRing Width="14" Height="14" IsIndeterminate="True" Margin="0,0,6,0"
                                                         VerticalAlignment="Center"
                                                         Visibility="{Binding CheckVitalsCommand.IsRunning, Converter={StaticResource BoolToVis}}" />
                                        <ui:SymbolIcon Symbol="Pulse24" FontSize="14" Margin="0,0,6,0"
                                                       VerticalAlignment="Center">
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CheckVitalsCommand.IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Check Vitals" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CheckVitalsCommand.IsRunning}" Value="True">
                                                            <Setter Property="Text" Value="Checking…" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </ui:Button.Content>
                            </ui:Button>
                        </StackPanel>

                        <!-- Connection callout: shown only when this row's vitals came via the SMB/DCOM
                             fallback (WinRM was unusable). Surfaces WHAT the WinRM failure was + how to fix,
                             with the actual error (copyable) tucked into an expander. -->
                        <Border Margin="0,12,0,0" Padding="14,12" CornerRadius="6"
                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                                Visibility="{Binding Computer.WinRmDegraded, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Warning24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                    <ui:TextBlock Text="Connection" FontTypography="BodyStrong" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding Computer.WinRmStateCaption}" />
                                <!-- Open by default: this callout only appears when WinRM was degraded, so the
                                     fix is exactly what the operator opened the window to read. -->
                                <Expander Margin="0,8,0,0" Header="What happened &amp; how to fix" IsExpanded="True">
                                    <StackPanel Margin="0,8,0,0">
                                        <Border Height="1" Margin="0,0,0,8"
                                                Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                                        <ItemsControl ItemsSource="{Binding Computer.WinRmFix}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="•" Margin="0,0,8,0" VerticalAlignment="Top"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- The exact WinRM error, behind its own toggle so a long stack doesn't push the
                                             bullets off-screen. Read-only + selectable so it copies cleanly into a ticket. -->
                                        <Expander Margin="0,8,0,0" Header="Show error">
                                            <TextBox Text="{Binding Computer.WinRmFailureDetail, Mode=OneWay, TargetNullValue='(no detail captured)'}"
                                                     IsReadOnly="True" TextWrapping="Wrap" BorderThickness="0" Padding="0" Margin="0,6,0,0"
                                                     Background="Transparent" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                     FontFamily="Cascadia Mono, Consolas" MaxHeight="90"
                                                     VerticalScrollBarVisibility="Auto"
                                                     ToolTip="Select to copy the exact error." />
                                        </Expander>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <!-- Everything below only makes sense once vitals have been read. -->
                        <StackPanel Visibility="{Binding Computer.VitalsCheckedAt, Converter={StaticResource NotNullToVis}}">
                            <!-- Triage action status + busy spinner (shown once an action has run). -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                        Visibility="{Binding TriageStatus, Converter={StaticResource StringToVis}}">
                                <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding TriageStatus}" TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Border Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <ui:TextBlock Text="Why this score" FontTypography="BodyStrong" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding Computer.VitalityReasons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:SymbolIcon Grid.Column="0" Symbol="Warning24" FontSize="14" Margin="0,1,8,0" VerticalAlignment="Top" Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <ui:TextBlock Text="Readings" FontTypography="BodyStrong" Margin="0,0,0,6" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <ui:TextBlock Grid.Row="0" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,3" Text="System drive free" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,3"
                                                   Text="{Binding Computer.Vitals.SystemDriveFreePercent, StringFormat='{}{0:0.#}%', TargetNullValue='—'}" />
                                        <ui:TextBlock Grid.Row="1" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,3" Text="Memory used" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,3"
                                                   Text="{Binding Computer.Vitals.MemoryUsedPercent, StringFormat='{}{0:0}%', TargetNullValue='—'}" />
                                        <ui:TextBlock Grid.Row="2" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,3" Text="CPU load" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,3"
                                                   Text="{Binding Computer.Vitals.CpuLoadPercent, StringFormat='{}{0:0}%', TargetNullValue='—'}" />
                                        <ui:TextBlock Grid.Row="3" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,3" Text="Last boot" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,3"
                                                   Text="{Binding Computer.Vitals.LastBootTime, StringFormat=g, TargetNullValue='—'}" />
                                        <ui:TextBlock Grid.Row="4" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,0" Text="Reboot pending" />
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="{Binding Computer.RebootRequired, Converter={StaticResource YesNo}}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <ui:TextBlock Text="Drives" FontTypography="BodyStrong" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding Computer.Vitals.Drives}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,2" TextWrapping="Wrap">
                                                    <Run Text="{Binding Letter, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="  " /><Run Text="{Binding FreePercent, Mode=OneWay, StringFormat='{}{0:0.#}% free'}" /><Run Text="  ·  " /><Run Text="{Binding FreeGb, Mode=OneWay, StringFormat='{}{0:0.#}'}" /><Run Text=" / " /><Run Text="{Binding SizeGb, Mode=OneWay, StringFormat='{}{0:0.#} GB'}" />
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:Button Content="Free up space…" Margin="0,10,0,0" Padding="10,4" HorizontalAlignment="Left"
                                               Click="OnFreeDiskSpace" IsEnabled="{Binding IsIdle}"
                                               ToolTip="Clear TEMP, the Windows Update cache, and the recycle bin on the system drive." />
                                </StackPanel>
                            </Border>

                            <!-- Stopped auto-start services: only shown when there are any (each row has a
                                 Start button — real triage). Hidden on clean boxes and on DCOM-fallback rows
                                 (which don't gather services), so no empty card. -->
                            <Border Style="{StaticResource SectionCard}"
                                    Visibility="{Binding Computer.StoppedAutoServiceCount, Converter={StaticResource NonZeroToVis}}">
                                <StackPanel>
                                    <ui:TextBlock Text="Stopped auto-start services" FontTypography="BodyStrong" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding Computer.Vitals.StoppedAutoServices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <ui:Button Grid.Column="1" Content="Start" Padding="10,2" Margin="8,0,0,0"
                                                           Command="{Binding DataContext.StartServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           ToolTip="Start this service now" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Top processes (by memory)" FontTypography="BodyStrong" VerticalAlignment="Center" />
                                        <ui:Button Grid.Column="1" Content="Load" Padding="10,2"
                                                   Command="{Binding LoadProcessesCommand}" IsEnabled="{Binding IsIdle}"
                                                   ToolTip="List the top processes so you can end a runaway one." />
                                    </Grid>
                                    <ui:DataGrid ItemsSource="{Binding TopProcesses}"
                                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal" MaxHeight="220">
                                        <ui:DataGrid.Columns>
                                            <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="Auto" />
                                            <DataGridTextColumn Header="Memory (MB)" Binding="{Binding WorkingSetMb, StringFormat=N0}" Width="Auto" MinWidth="90" />
                                            <DataGridTextColumn Header="CPU (s)" Binding="{Binding CpuSeconds, StringFormat=N0, TargetNullValue=—}" Width="Auto" MinWidth="70" />
                                            <DataGridTemplateColumn Header="" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ui:Button Content="End" Padding="10,1" Margin="4,1" Click="OnEndProcess"
                                                                   IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=ui:DataGrid}}"
                                                                   ToolTip="Force-end this process" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </ui:DataGrid.Columns>
                                    </ui:DataGrid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Applicable updates"
                     Visibility="{Binding Computer.LastScannedApplicable, Converter={StaticResource NotNullToVis}}">
                <ui:DataGrid ItemsSource="{Binding Computer.ApplicableUpdates}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" MinWidth="80" />
                        <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySizeMb, StringFormat={}{0:N1} MB, TargetNullValue=—}" Width="Auto" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
            <TabItem Header="Installed updates"
                     Visibility="{Binding Computer.LastScannedInstalled, Converter={StaticResource NotNullToVis}}">
                <ui:DataGrid ItemsSource="{Binding Computer.InstalledUpdates}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" MinWidth="80" />
                        <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Installed" Binding="{Binding InstalledAt, StringFormat=yyyy-MM-dd}" Width="Auto" MinWidth="90" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
            <TabItem Header="Messages">
                <ui:DataGrid ItemsSource="{Binding Messages}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None">
                    <ui:DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon Margin="6,0" FontSize="14"
                                                   Symbol="{Binding Severity, Converter={StaticResource SeveritySymbol}}"
                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                                                   ToolTip="{Binding Severity}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
