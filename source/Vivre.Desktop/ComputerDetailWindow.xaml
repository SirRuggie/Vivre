<ui:FluentWindow x:Class="Vivre.Desktop.ComputerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        mc:Ignorable="d"
        Title="Machine details"
        Height="640" Width="680"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <local:StatusBrushConverter x:Key="StatusBrush" />
        <local:StatusSymbolConverter x:Key="StatusSymbol" />
        <local:BoolStateTextConverter x:Key="YesNo" />
        <local:PhaseChipLabelConverter x:Key="PhaseLabel" />
        <local:LogSeverityBrushConverter x:Key="SeverityBrush" />
        <local:LogSeveritySymbolConverter x:Key="SeveritySymbol" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:NotNullToVisibilityConverter x:Key="NotNullToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Machine details" />

        <!-- Header card: identity + current update state. -->
        <Border Grid.Row="1" Margin="16,4,16,8" Padding="14,12" CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"
                                   Symbol="{Binding Computer.IsOnline, Converter={StaticResource StatusSymbol}}"
                                   Foreground="{Binding Computer.IsOnline, Converter={StaticResource StatusBrush}}"
                                   ToolTip="{Binding Computer.LastStatus}" />
                    <ui:TextBlock Text="{Binding Computer.Name}" FontTypography="Subtitle" VerticalAlignment="Center" />
                    <Border CornerRadius="8" Padding="8,1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                    </DataTrigger>
                                    <!-- Available = call-to-action (updates ready to install): accent fill so it
                                         pops past the quiet working/idle tints. -->
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Computer.PatchState, Converter={StaticResource PhaseLabel}}"
                                   FontSize="11" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="{Binding Computer.UpdateMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Scanning">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Downloading">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Installing">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Uninstalling">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Available">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="RebootPending">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Done">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Computer.PatchState}" Value="Error">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Computer.RebootMessage}" />

                <ProgressBar Margin="0,8,0,0" Height="6" Minimum="0" Maximum="100"
                             Value="{Binding Computer.UpdateProgress, Mode=OneWay, FallbackValue=0, TargetNullValue=0}" />

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:TextBlock Grid.Row="0" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,2" Text="OS" />
                    <ui:TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,2" TextWrapping="Wrap"
                                  Text="{Binding Computer.OperatingSystem, TargetNullValue='—'}" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,2" Text="Reboot pending" />
                    <ui:TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,2"
                                  Text="{Binding Computer.RebootRequired, Converter={StaticResource YesNo}}" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="0" Appearance="Secondary" Margin="0,0,12,0" Text="Scheduled" />
                    <ui:TextBlock Grid.Row="2" Grid.Column="1"
                                  Text="{Binding Computer.ScheduledNextRun, StringFormat=g, TargetNullValue='—'}" />
                </Grid>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Margin="16,0,16,16">
            <TabItem Header="Vitals">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="4,8,4,4">
                        <!-- Score + band + when it was read.
                             DataTriggers + DynamicResource so colors re-resolve on theme switch. -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border CornerRadius="8" Padding="12,4" MinWidth="40" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Healthy">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Warning">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Critical">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Computer.VitalityScore, TargetNullValue=—}"
                                           FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Healthy">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Warning">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Computer.VitalityBand}" Value="Critical">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <ui:TextBlock Text="{Binding Computer.VitalityBand, TargetNullValue='Not checked yet'}" FontTypography="BodyStrong" />
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Text="{Binding Computer.VitalsCheckedAt, StringFormat='Checked {0:g}', TargetNullValue='Run Check Vitals (Machines view) to populate this.'}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Everything below only makes sense once vitals have been read. -->
                        <StackPanel Visibility="{Binding Computer.VitalsCheckedAt, Converter={StaticResource NotNullToVis}}">
                            <!-- Triage action status + busy spinner (shown once an action has run). -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                        Visibility="{Binding TriageStatus, Converter={StaticResource StringToVis}}">
                                <ui:ProgressRing Width="16" Height="16" IsIndeterminate="True" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{Binding TriageStatus}" TextWrapping="Wrap" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ui:TextBlock Text="Why this score" FontTypography="BodyStrong" Margin="0,16,0,4" />
                            <ItemsControl ItemsSource="{Binding Computer.VitalityReasons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <ui:SymbolIcon Symbol="Warning24" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ui:TextBlock Text="Readings" FontTypography="BodyStrong" Margin="0,16,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ui:TextBlock Grid.Row="0" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,2" Text="System drive free" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,2"
                                           Text="{Binding Computer.Vitals.SystemDriveFreePercent, StringFormat='{}{0:0.#}%', TargetNullValue='—'}" />
                                <ui:TextBlock Grid.Row="1" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,2" Text="Memory used" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,2"
                                           Text="{Binding Computer.Vitals.MemoryUsedPercent, StringFormat='{}{0:0}%', TargetNullValue='—'}" />
                                <ui:TextBlock Grid.Row="2" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,2" Text="CPU load" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,2"
                                           Text="{Binding Computer.Vitals.CpuLoadPercent, StringFormat='{}{0:0}%', TargetNullValue='—'}" />
                                <ui:TextBlock Grid.Row="3" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,2" Text="Last boot" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,2"
                                           Text="{Binding Computer.Vitals.LastBootTime, StringFormat=g, TargetNullValue='—'}" />
                                <ui:TextBlock Grid.Row="4" Grid.Column="0" Appearance="Secondary" Margin="0,0,16,0" Text="Reboot pending" />
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Text="{Binding Computer.Vitals.RebootPending, Converter={StaticResource YesNo}}" />
                            </Grid>

                            <ui:TextBlock Text="Drives" FontTypography="BodyStrong" Margin="0,16,0,4" />
                            <ItemsControl ItemsSource="{Binding Computer.Vitals.Drives}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,1" TextWrapping="Wrap">
                                            <Run Text="{Binding Letter, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="  " /><Run Text="{Binding FreePercent, Mode=OneWay, StringFormat='{}{0:0.#}% free'}" /><Run Text="  ·  " /><Run Text="{Binding FreeGb, Mode=OneWay, StringFormat='{}{0:0.#}'}" /><Run Text=" / " /><Run Text="{Binding SizeGb, Mode=OneWay, StringFormat='{}{0:0.#} GB'}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ui:Button Content="Free up space…" Margin="0,8,0,0" Padding="10,4" HorizontalAlignment="Left"
                                       Click="OnFreeDiskSpace" IsEnabled="{Binding IsIdle}"
                                       ToolTip="Clear TEMP, the Windows Update cache, and the recycle bin on the system drive." />

                            <ui:TextBlock Text="Stopped auto-start services" FontTypography="BodyStrong" Margin="0,16,0,4" />
                            <ItemsControl ItemsSource="{Binding Computer.Vitals.StoppedAutoServices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <ui:Button Grid.Column="1" Content="Start" Padding="10,2" Margin="8,0,0,0"
                                                       Command="{Binding DataContext.StartServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}"
                                                       IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       ToolTip="Start this service now" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,16,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="Top processes (by memory)" FontTypography="BodyStrong" VerticalAlignment="Center" />
                                <ui:Button Grid.Column="1" Content="Load" Padding="10,2"
                                           Command="{Binding LoadProcessesCommand}" IsEnabled="{Binding IsIdle}"
                                           ToolTip="List the top processes so you can end a runaway one." />
                            </Grid>
                            <ui:DataGrid ItemsSource="{Binding TopProcesses}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" MaxHeight="220">
                                <ui:DataGrid.Columns>
                                    <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="Auto" />
                                    <DataGridTextColumn Header="Memory (MB)" Binding="{Binding WorkingSetMb, StringFormat=N0}" Width="Auto" MinWidth="90" />
                                    <DataGridTextColumn Header="CPU (s)" Binding="{Binding CpuSeconds, StringFormat=N0, TargetNullValue=—}" Width="Auto" MinWidth="70" />
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Content="End" Padding="10,1" Margin="4,1" Click="OnEndProcess"
                                                           IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=ui:DataGrid}}"
                                                           ToolTip="Force-end this process" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </ui:DataGrid.Columns>
                            </ui:DataGrid>

                            <ui:TextBlock Text="Recent error / critical events (24h)" FontTypography="BodyStrong" Margin="0,16,0,4" />
                            <ui:DataGrid ItemsSource="{Binding Computer.Vitals.RecentErrorEvents}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" MaxHeight="220">
                                <ui:DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat=HH:mm}" Width="Auto" />
                                    <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="Auto" />
                                    <DataGridTextColumn Header="Source" Binding="{Binding Provider}" Width="Auto" MinWidth="80" />
                                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto" />
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                <Setter Property="ToolTip" Value="{Binding Message}" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </ui:DataGrid.Columns>
                            </ui:DataGrid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Applicable updates"
                     Visibility="{Binding Computer.LastScannedApplicable, Converter={StaticResource NotNullToVis}}">
                <ui:DataGrid ItemsSource="{Binding Computer.ApplicableUpdates}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" MinWidth="80" />
                        <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="Auto" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
            <TabItem Header="Installed updates"
                     Visibility="{Binding Computer.LastScannedInstalled, Converter={StaticResource NotNullToVis}}">
                <ui:DataGrid ItemsSource="{Binding Computer.InstalledUpdates}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <ui:DataGrid.Columns>
                        <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" MinWidth="80" />
                        <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Installed" Binding="{Binding InstalledAt, StringFormat=yyyy-MM-dd}" Width="Auto" MinWidth="90" />
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
            <TabItem Header="Messages">
                <ui:DataGrid ItemsSource="{Binding Messages}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None">
                    <ui:DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon Margin="6,0" FontSize="14"
                                                   Symbol="{Binding Severity, Converter={StaticResource SeveritySymbol}}"
                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                                                   ToolTip="{Binding Severity}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </ui:DataGrid.Columns>
                </ui:DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>
