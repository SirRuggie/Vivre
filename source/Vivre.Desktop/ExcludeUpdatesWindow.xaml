<ui:FluentWindow x:Class="Vivre.Desktop.ExcludeUpdatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Exclude updates"
        Height="460" Width="480"
        MinHeight="400" MinWidth="400"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Exclude updates" Icon="{ui:SymbolIcon Filter24}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,0">
            <StackPanel>
                <!-- Section header -->
                <ui:TextBlock Text="Exclusion terms" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" Margin="0,0,0,12"
                              MaxWidth="420"
                              Text="Comma-separated terms to skip during scans and installs. Any update whose title contains one of these terms (case-insensitive) will be excluded." />

                <!-- Input box -->
                <ui:TextBox x:Name="InputBox"
                            PlaceholderText="e.g. SQL, Silverlight, Edge"
                            TextWrapping="Wrap"
                            AcceptsReturn="False"
                            KeyDown="OnInputKeyDown" />

                <ui:TextBlock Appearance="Secondary" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"
                              MaxWidth="420"
                              Text="One term per update product you want to skip. Leave blank to install everything the scan finds." />

                <!-- Current terms list (shown when terms exist) -->
                <Border x:Name="TermsPanel" Margin="0,16,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,12" />
                        <ui:TextBlock Text="Currently excluded" FontTypography="BodyStrong" Margin="0,0,0,6" />
                        <ItemsControl x:Name="TermsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <ui:SymbolIcon Symbol="Prohibited24" FontSize="14" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                       VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,16">
            <ui:Button x:Name="SaveButton" Appearance="Primary" Icon="{ui:SymbolIcon Checkmark24}"
                       Content="Save" Click="OnSave" IsDefault="True" />
            <ui:Button Margin="8,0,0,0" Content="Cancel" Click="OnCancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
