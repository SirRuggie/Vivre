<ui:FluentWindow x:Class="Vivre.Desktop.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        xmlns:vm="clr-namespace:Vivre.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="How to use Vivre"
        Height="720" Width="680"
        MinHeight="420" MinWidth="520"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <local:StringToVisibilityConverter x:Key="TipVis" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="How to use Vivre"
                     Icon="{ui:SymbolIcon BookQuestionMark24}" />

        <!-- Search + expand controls -->
        <Grid Grid.Row="1" Margin="24,8,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search — e.g. reboot, schedule, uninstall, WinRM…"
                        Icon="{ui:SymbolIcon Search24}"
                        ClearButtonEnabled="True" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <ui:Button Appearance="Secondary" ToolTip="Expand all"
                           Command="{Binding ExpandAllCommand}"
                           Icon="{ui:SymbolIcon ChevronDown24}" />
                <ui:Button Appearance="Secondary" Margin="6,0,0,0" ToolTip="Collapse all"
                           Command="{Binding CollapseAllCommand}"
                           Icon="{ui:SymbolIcon ChevronUp24}" />
            </StackPanel>
        </Grid>

        <!-- Grouped accordion -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0,24,16">
            <ItemsControl ItemsSource="{Binding Topics}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <ui:TextBlock Text="{Binding Name}" FontTypography="Subtitle"
                                              Margin="0,16,0,8" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:HelpTopic}">
                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Margin="0,0,0,8" Padding="4,2">
                            <Expander IsExpanded="{Binding IsExpanded}" Background="Transparent"
                                      BorderThickness="0">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="18"
                                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                        <ui:TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                      Margin="10,0,0,0" VerticalAlignment="Center"
                                                      TextWrapping="Wrap" />
                                    </StackPanel>
                                </Expander.Header>

                                <StackPanel Margin="34,4,12,8">
                                    <ItemsControl ItemsSource="{Binding Lines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                              Appearance="Secondary" Margin="0,0,0,4" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Optional tip box -->
                                    <Border Visibility="{Binding Tip, Converter={StaticResource TipVis}}"
                                            Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                                            CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Lightbulb24" FontSize="16"
                                                           VerticalAlignment="Top" Margin="0,1,8,0"
                                                           Foreground="{DynamicResource SystemFillColorAttentionBrush}" />
                                            <ui:TextBlock Text="{Binding Tip}" TextWrapping="Wrap"
                                                          Appearance="Secondary" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
