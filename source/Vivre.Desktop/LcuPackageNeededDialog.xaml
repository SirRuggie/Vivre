<ui:FluentWindow x:Class="Vivre.Desktop.LcuPackageNeededDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Add the Server 2016 update"
        Height="480" Width="560"
        MinHeight="400" MinWidth="500"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Add the Server 2016 update">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Box24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,8,20,8">
            <StackPanel>
                <!-- What's wrong, in plain terms (set from the resolver's message). No box was touched. -->
                <ui:InfoBar x:Name="ProblemBar" Severity="Warning" IsOpen="True" IsClosable="False"
                            Title="The update package isn't ready — no machine was touched" Margin="0,0,0,16" />

                <!-- 1. WHAT it needs -->
                <TextBlock Text="1.  What Vivre needs" FontWeight="SemiBold" Margin="0,0,0,3" />
                <TextBlock x:Name="NeedsText" FontSize="13" Margin="14,0,0,2" />
                <TextBlock Text="The Server 2016 cumulative update for this month (a single .msu file)."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                           Margin="14,0,0,14" TextWrapping="Wrap" />

                <!-- 2. WHERE to get it -->
                <TextBlock Text="2.  Get it from the Microsoft Update Catalog" FontWeight="SemiBold" Margin="0,0,0,3" />
                <TextBlock Margin="14,0,0,6" TextWrapping="Wrap">
                    <Hyperlink Click="OnOpenCatalog"><Run x:Name="CatalogLinkText" Text="https://www.catalog.update.microsoft.com" /></Hyperlink>
                </TextBlock>
                <ui:Button Content="Open the Catalog in your browser" Icon="{ui:SymbolIcon Globe24}"
                           Click="OnOpenCatalog" Margin="14,0,0,16" />

                <!-- 3. WHERE to put it -->
                <TextBlock Text="3.  Put the downloaded .msu in this folder" FontWeight="SemiBold" Margin="0,0,0,4" />
                <Grid Margin="14,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" x:Name="FolderBox" IsReadOnly="True"
                                VerticalAlignment="Center" Margin="0,0,8,0"
                                ToolTip="Read-only — select the text to copy the path." />
                    <ui:Button Grid.Column="1" Content="Open folder" Icon="{ui:SymbolIcon FolderOpen24}"
                               Click="OnOpenFolder" />
                </Grid>

                <!-- 4. WHAT next -->
                <TextBlock Text="4.  Then drop the .msu there and click &quot;Stage now&quot; below."
                           FontWeight="SemiBold" Margin="0,14,0,0" TextWrapping="Wrap" />
                <TextBlock Text="Vivre never downloads the file for you — it only reads it from this folder."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                           Margin="14,4,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="20,12" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Stage now" Appearance="Primary" IsDefault="True"
                           Click="OnStageNow" Margin="0,0,8,0"
                           ToolTip="Re-check the folder and start staging if the file is now there." />
                <ui:Button Content="Cancel" IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
