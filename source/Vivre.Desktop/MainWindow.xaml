<ui:FluentWindow x:Class="Vivre.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        xmlns:vm="clr-namespace:Vivre.Desktop.ViewModels"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:updates="clr-namespace:Vivre.Core.Updates;assembly=Vivre.Core"
        mc:Ignorable="d"
        Title="Vivre"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Height="780" Width="1360"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
        <local:EnumEqualsConverter x:Key="EnumEquals" />
        <local:LogSeverityBrushConverter x:Key="SeverityBrush" />
        <local:LogSeveritySymbolConverter x:Key="SeveritySymbol" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <local:FleetSectionToVisibilityConverter x:Key="FleetSectionToVis" />
        <local:CompactThicknessConverter x:Key="CompactThickness" />

        <!-- Toolbar button label: collapsed in compact mode, visible in expanded mode.
             Bind to ToolbarCompact on the MainWindow ancestor via a DataTrigger. -->
        <Style x:Key="ToolbarLabelStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════════════
             COMMAND-BAR BUTTON STYLES — Task-Manager / Fluent CommandBar pattern.
             Frameless at rest (no border, no fill), subtle fill on hover/press,
             all using DynamicResource Fluent theme tokens (light + dark safe).
             ═══════════════════════════════════════════════════════════════════════ -->

        <!-- Frameless ui:Button for the command bar.
             Appearance=Transparent zeroes the rest fill via the template trigger.
             We then override MouseOverBackground/PressedBackground/border so the
             hover uses Fluent SubtleFill tokens instead of the default elevated fill.
             BorderThickness=0 + BorderBrush=Transparent removes the rest-state box.
             BasedOn preserves all sizing, padding, icon layout, and disabled state. -->
        <Style x:Key="ToolbarButtonStyle" TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance"          Value="Transparent" />
            <Setter Property="BorderThickness"     Value="0" />
            <Setter Property="BorderBrush"         Value="Transparent" />
            <Setter Property="MouseOverBackground" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="MouseOverBorderBrush" Value="Transparent" />
            <Setter Property="PressedBackground"   Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
            <Setter Property="PressedBorderBrush"  Value="Transparent" />
        </Style>

        <!-- Frameless ui:SplitButton.  SplitButton is BasedOn DefaultUiButtonStyle and
             exposes the same MouseOverBackground / PressedBackground attached properties,
             so identical overrides apply.  The inner PART_Content / PART_Toggle borders
             each bind Background from the control's MouseOverBackground / PressedBackground
             properties, so setting them here flows through correctly. -->
        <Style x:Key="ToolbarSplitButtonStyle" TargetType="ui:SplitButton"
               BasedOn="{StaticResource {x:Type ui:SplitButton}}">
            <Setter Property="Appearance"           Value="Transparent" />
            <Setter Property="BorderThickness"      Value="0" />
            <Setter Property="BorderBrush"          Value="Transparent" />
            <Setter Property="MouseOverBackground"  Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="MouseOverBorderBrush" Value="Transparent" />
            <Setter Property="PressedBackground"    Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
            <Setter Property="PressedBorderBrush"   Value="Transparent" />
        </Style>

        <!-- Monitor ToggleButton — frameless rest; subtle fill on hover/press;
             ON state: accent-coloured icon+label (AccentTextFillColorPrimaryBrush) +
             faint accent-tinted background (SubtleFillColorSecondaryBrush tinted by the
             ToggleButtonBackgroundChecked token) — clearly "on" without a solid box.
             We provide a minimal ControlTemplate so the trigger logic is fully owned here:
             the WPF-UI DefaultToggleButtonStyle trigger for IsChecked=True sets a solid
             ToggleButtonBackgroundChecked fill, which we don't want.
             CornerRadius bound to the Fluent ControlCornerRadius token for consistency. -->
        <Style x:Key="ToolbarMonitorStyle" TargetType="ToggleButton">
            <Setter Property="FocusVisualStyle"         Value="{DynamicResource DefaultControlFocusVisualStyle}" />
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="Foreground"               Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush"              Value="Transparent" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="HorizontalAlignment"      Value="Left" />
            <Setter Property="VerticalAlignment"        Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment"   Value="Center" />
            <Setter Property="FontSize"                 Value="{DynamicResource ControlContentThemeFontSize}" />
            <Setter Property="SnapsToDevicePixels"      Value="True" />
            <Setter Property="OverridesDefaultStyle"    Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ContentBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover (unchecked) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked"   Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                            <!-- Pressed (unchecked) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed"  Value="True" />
                                    <Condition Property="IsChecked"  Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                            </MultiTrigger>
                            <!-- ON state: faint accent-tinted background + accent foreground.
                                 SubtleFillColorSecondaryBrush gives the tinted look in both themes;
                                 AccentTextFillColorPrimaryBrush colours icon + label in accent. -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsEnabled" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </MultiTrigger>
                            <!-- Hover (checked) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked"   Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </MultiTrigger>
                            <!-- Pressed (checked) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground"
                                        Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </MultiTrigger>
                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ContentBorder" Property="Background"
                                        Value="Transparent" />
                                <Setter TargetName="ContentPresenter" Property="TextElement.Foreground"
                                        Value="{DynamicResource TextFillColorDisabledBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </ui:FluentWindow.Resources>

    <!-- Keyboard accelerators → routed to code-behind. -->
    <ui:FluentWindow.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.NewTabKey}" Executed="OnNewTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.CloseTabKey}" Executed="OnCloseTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.FocusAddKey}" Executed="OnFocusAddKey" />
        <CommandBinding Command="{x:Static local:MainWindow.RenameTabKey}" Executed="OnRenameTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.ToggleModeKey}" Executed="OnToggleModeKey" />
        <CommandBinding Command="{x:Static local:MainWindow.RefreshKey}" Executed="OnRefreshKey" />
        <CommandBinding Command="{x:Static local:MainWindow.InstallKey}" Executed="OnInstallKey" />
        <CommandBinding Command="{x:Static local:MainWindow.HelpKey}" Executed="OnHelpKey" />
    </ui:FluentWindow.CommandBindings>
    <ui:FluentWindow.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{x:Static local:MainWindow.NewTabKey}" />
        <KeyBinding Modifiers="Control" Key="W" Command="{x:Static local:MainWindow.CloseTabKey}" />
        <KeyBinding Modifiers="Control" Key="L" Command="{x:Static local:MainWindow.FocusAddKey}" />
        <KeyBinding Key="F2" Command="{x:Static local:MainWindow.RenameTabKey}" />
        <KeyBinding Modifiers="Control" Key="M" Command="{x:Static local:MainWindow.ToggleModeKey}" />
        <KeyBinding Key="F5" Command="{x:Static local:MainWindow.RefreshKey}" />
        <KeyBinding Modifiers="Control" Key="Return" Command="{x:Static local:MainWindow.InstallKey}" />
        <KeyBinding Key="F1" Command="{x:Static local:MainWindow.HelpKey}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vivre" Height="36">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.png" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- System tray icon (no visual footprint). -->
        <tb:TaskbarIcon x:Name="TrayIcon" Grid.Row="0"
                        IconSource="pack://application:,,,/Assets/AppIcon.png"
                        ToolTipText="Vivre — the heartbeat of your fleet"
                        TrayMouseDoubleClick="OnTrayOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="OnTrayOpen">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="WindowNew24" /></MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Exit" Click="OnTrayExit">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="Power24" /></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Shell row 1: NavigationView pane beside the keep-alive content host.
             Column 0 = the nav pane (compact 48 px or open 200 px — code-behind sets the Width);
             Column 1 = the content area (*). NavView spans both columns so its left pane renders
             in column 0 and its (empty) right frame renders in column 1. ContentHost is placed in
             column 1 only, so WPF naturally constrains it to the content-area width.
             Navigate() is never called on NavView; SelectionChanged only toggles the Visibility of
             sections in ContentHost (keep-alive: sections are never rebuilt on nav switch). -->
        <Grid Grid.Row="1" x:Name="ShellGrid">
            <Grid.ColumnDefinitions>
                <!-- Column 0: nav pane width — set from code-behind (48 compact, 200 open). -->
                <ColumnDefinition x:Name="NavPaneColumn" Width="48" />
                <!-- Column 1: content area — takes the remaining width. -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- NavigationView — pane-only (no Navigate() calls; built-in Frame is empty).
                 Spans both columns so the left pane occupies column 0 and the empty frame occupies
                 column 1. LeftCompact: icons shown when compact (pane closed), icons+labels when open. -->
            <ui:NavigationView x:Name="NavView" Grid.ColumnSpan="2"
                               PaneDisplayMode="Left"
                               IsPaneOpen="False"
                               IsPaneToggleVisible="True"
                               IsBackButtonVisible="Collapsed"
                               AlwaysShowHeader="False"
                               HeaderVisibility="Collapsed"
                               FrameMargin="0"
                               CompactPaneLength="48"
                               OpenPaneLength="200"
                               PaneOpened="OnNavPaneOpened"
                               PaneClosed="OnNavPaneClosed"
                               ItemInvoked="OnNavItemInvoked">

                <ui:NavigationView.MenuItems>
                    <!-- Fleet parent: collapsible, NOT a nav destination itself. Children are the real
                         destinations. HasFlyout=False keeps the pane open on click (no popup flyout). -->
                    <ui:NavigationViewItem x:Name="FleetNavItem"
                                           Content="Fleet"
                                           Icon="{ui:SymbolIcon Desktop24}"
                                           ToolTip="Fleet — Health check and Patching workspaces"
                                           IsExpanded="True"
                                           Click="OnFleetNavClick">
                        <ui:NavigationViewItem.MenuItems>
                            <ui:NavigationViewItem x:Name="HealthNavItem"
                                                   Content="Health"
                                                   Icon="{ui:SymbolIcon HeartPulse24}"
                                                   ToolTip="Health — ping, vitals, SCCM actions for your fleet"
                                                   Click="OnHealthNavClick" />
                            <ui:NavigationViewItem x:Name="PatchingNavItem"
                                                   Content="Patching"
                                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                                   ToolTip="Patching — scan and install Windows Updates"
                                                   Click="OnPatchingNavClick" />
                        </ui:NavigationViewItem.MenuItems>
                    </ui:NavigationViewItem>
                    <ui:NavigationViewItem x:Name="ScriptsNavItem"
                                           Content="Scripts"
                                           Icon="{ui:SymbolIcon Code24}"
                                           ToolTip="Script library — browse, edit, add and delete PowerShell scripts"
                                           Click="OnScriptsNavClick" />
                    <ui:NavigationViewItem x:Name="RdpNavItem"
                                           Content="Cross-Domain RDP"
                                           Icon="{ui:SymbolIcon PlugConnected24}"
                                           ToolTip="Cross-Domain RDP — connect to hosts on other domains"
                                           Visibility="{Binding IsCrossDomainRdpAvailable, Converter={StaticResource BoolToVis}}"
                                           Click="OnRdpNavClick" />
                </ui:NavigationView.MenuItems>

                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem x:Name="SettingsNavItem"
                                           Content="Settings"
                                           Icon="{ui:SymbolIcon Settings24}"
                                           ToolTip="Theme, credentials, auto-check, columns, help"
                                           Click="OnSettingsNavClick" />
                </ui:NavigationView.FooterMenuItems>

            </ui:NavigationView>

            <!-- Keep-alive content host — column 1 of the ShellGrid (the content area to the right of
                 the nav pane). Both sections live here permanently; SelectionChanged toggles their
                 Visibility only — the workspace (TabControlEx + loaded state) is NEVER rebuilt when
                 switching Computers ↔ Settings. -->
            <Grid x:Name="ContentHost" Grid.Column="1">

                <!-- ═════════════════ COMPUTERS SECTION ══════════════════════ -->
                <Grid x:Name="ComputersSection" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition x:Name="SplitterRow" Height="0" />
                        <RowDefinition x:Name="ActivityRow" Height="0" MinHeight="0" />
                    </Grid.RowDefinitions>

                    <!-- Command bar: left action cluster (Grid.Column 0, *) and the right input cluster
                         (Grid.Column 1, Auto: Lists / Add-computer box / Add / Paste). The * column gives the
                         left actions the remaining width and clips them when the window is narrow, so the
                         right input cluster is always reachable. -->
                    <Grid x:Name="CommandBarGrid" Grid.Row="0" Margin="12,2,12,6"
                          Visibility="{Binding IsWorkspaceTab, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left action cluster. Named so AdaptiveLayoutController can measure it. -->
                        <StackPanel x:Name="ActionCluster" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Hot path: Ping All (split), Check Vitals, Monitor.
                                 All buttons use icon+label in a centred StackPanel as Content (no Icon= attribute)
                                 so collapsing the label TextBlock leaves the icon correctly centred. -->
                            <ui:SplitButton Style="{StaticResource ToolbarSplitButtonStyle}"
                                            Command="{Binding SelectedTab.PingAllCommand}"
                                            ToolTip="Ping All — ping every machine in this tab (F5)">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                                    <TextBlock Text="Ping All" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                                <ui:SplitButton.Flyout>
                                    <ContextMenu>
                                        <MenuItem Header="Ping Offline only" Command="{Binding SelectedTab.PingOfflineCommand}" />
                                    </ContextMenu>
                                </ui:SplitButton.Flyout>
                            </ui:SplitButton>
                            <ui:Button Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Command="{Binding SelectedTab.CheckVitalsCommand}"
                                       ToolTip="Check Vitals — pull SCCM client health AND deep OS vitals. Read-only.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,6,0" />
                                    <TextBlock Text="Check Vitals" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>
                            <ToggleButton Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}" Padding="11,6"
                                          Style="{StaticResource ToolbarMonitorStyle}"
                                          IsChecked="{Binding SelectedTab.IsMonitoring, Mode=TwoWay}"
                                          ToolTip="Monitor — continuously re-check online/offline. Stop halts it.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Eye24" Margin="0,0,6,0" />
                                    <TextBlock Text="Monitor" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ToggleButton>

                            <Border Width="1" Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='12,4;6,2'}" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!-- Operations: de-emphasised -->
                            <ui:Button Style="{StaticResource ToolbarButtonStyle}"
                                       Command="{Binding SelectedTab.RemoveOfflineCommand}"
                                       ToolTip="Remove Offline — remove every offline machine from this tab.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Delete24" Margin="0,0,6,0" />
                                    <TextBlock Text="Remove Offline" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Command="{Binding SelectedTab.StopCommand}"
                                       IsEnabled="{Binding SelectedTab.IsBusy}"
                                       ToolTip="Stop — cancel all running operations in this tab.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Stop24" Margin="0,0,6,0" />
                                    <TextBlock Text="Stop" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Command="{Binding SelectedTab.ClearResultsCommand}"
                                       ToolTip="Clear results — clear the Command result column on every row.">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Eraser24" Margin="0,0,6,0" />
                                    <TextBlock Text="Clear results" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>

                            <!-- Update options button — visible only in Patching mode. -->
                            <ui:Button x:Name="UpdateOptionsButton" Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}"
                                       AutomationProperties.Name="Update options"
                                       ToolTip="Update options — configure update source, drivers, and exclusions"
                                       Click="OnUpdateOptionsButtonClick">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Settings24" Margin="0,0,6,0" />
                                    <TextBlock Text="Update options" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab.IsUpdateMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <ui:Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Source">
                                            <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowSwap24" /></MenuItem.Icon>
                                            <MenuItem Header="Windows Update" Click="OnSourceWindowsUpdate">
                                                <MenuItem.Icon>
                                                    <RadioButton IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.WindowsUpdate}}"
                                                                 IsHitTestVisible="False" Focusable="False" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Microsoft Update" Click="OnSourceMicrosoftUpdate">
                                                <MenuItem.Icon>
                                                    <RadioButton IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.MicrosoftUpdate}}"
                                                                 IsHitTestVisible="False" Focusable="False" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Managed (WSUS/SCCM)" Click="OnSourceManaged">
                                                <MenuItem.Icon>
                                                    <RadioButton IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.Managed}}"
                                                                 IsHitTestVisible="False" Focusable="False" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Include drivers" IsCheckable="True"
                                                  IsChecked="{Binding SelectedTab.IncludeDrivers, Mode=TwoWay}">
                                            <MenuItem.Icon><ui:SymbolIcon Symbol="HardDrive24" /></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Exclude updates…" Click="OnOpenExcludeDialog">
                                            <MenuItem.Icon><ui:SymbolIcon Symbol="Filter24" /></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ui:Button.ContextMenu>
                            </ui:Button>

                            <!-- Divider: shown in update mode only, AND only when no rows are selected
                                 (selection bar owns Scan/Install when rows are selected). -->
                            <Border Width="1" Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='12,4;6,2'}" Background="{DynamicResource DividerStrokeColorDefaultBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab.IsUpdateMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTab.HasSelection}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Updates (update-mode only, and only when no rows selected — selection bar
                                 owns Scan/Install for the selection so both don't show simultaneously). -->
                            <ui:Button Command="{Binding SelectedTab.ScanTargetCommand}"
                                       ToolTip="Scan all — scan all machines in this tab for applicable updates.">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab.IsUpdateMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTab.HasSelection}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Search24" Margin="0,0,6,0" />
                                    <TextBlock Text="Scan all" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="InstallButton" Margin="{Binding ToolbarCompact, RelativeSource={RelativeSource AncestorType=local:MainWindow}, Converter={StaticResource CompactThickness}, ConverterParameter='8,0,0,0;2,0,0,0'}"
                                       IsEnabled="{Binding SelectedTab.IsBusy, Converter={StaticResource InverseBool}}"
                                       Click="OnInstallClick"
                                       ToolTip="Install all — download and install applicable updates on all machines in this tab (Ctrl+Enter).">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab.CanShowInstallToolbar}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedTab.HasSelection}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,6,0" />
                                    <TextBlock Text="Install all" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>

                        </StackPanel>

                        <!-- Right input cluster: Lists ▾ / Add-computer box / Add / Paste -->
                        <StackPanel x:Name="RightCluster" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <ui:Button x:Name="ListsButton"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Click="OnListsButtonClick"
                                       ToolTip="Lists — open, save, or delete a named machine list">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="DocumentBulletList24" Margin="0,0,6,0" />
                                    <TextBlock Text="Lists" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                                <ui:Button.ContextMenu>
                                    <ContextMenu Opened="OnListsFlyoutOpened">
                                        <MenuItem Header="Open list" Tag="OpenList" />
                                        <MenuItem Header="Save tab as list…" Click="OnSaveTabAsList" />
                                        <Separator />
                                        <MenuItem Header="Delete list" Tag="DeleteList" />
                                    </ContextMenu>
                                </ui:Button.ContextMenu>
                            </ui:Button>
                            <ui:TextBox x:Name="QuickAddBox" Width="180" Margin="8,0,0,0" PlaceholderText="Add computer…"
                                        ToolTip="Type a computer name and press Enter, or use Ctrl+L to jump here"
                                        KeyDown="OnQuickAddKeyDown" />
                            <ui:Button x:Name="AddButton" Margin="6,0,0,0"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Click="OnQuickAdd" ToolTip="Add — add this computer (or press Enter in the box)">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" Margin="0,0,6,0" />
                                    <TextBlock Text="Add" Style="{StaticResource ToolbarLabelStyle}" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button Margin="6,0,0,0"
                                       Style="{StaticResource ToolbarButtonStyle}"
                                       Click="OnPasteList"
                                       Height="{Binding ActualHeight, ElementName=AddButton}"
                                       VerticalContentAlignment="Center"
                                       AutomationProperties.Name="Paste a list of machines"
                                       ToolTip="Paste a list of machines from the clipboard">
                                <ui:SymbolIcon Symbol="ClipboardPaste24" />
                            </ui:Button>
                        </StackPanel>

                    </Grid>


                    <!-- Fleet section tab strips — two independent keep-alive TabControlEx instances,
                         one per Fleet section. Only one is Visible at a time (toggled by ActiveFleetSection)
                         but BOTH stay in the visual tree so their content is never destroyed on switch.
                         This is the critical keep-alive: switching Health↔Patching only toggles Visibility,
                         never removes a TabControlEx from the tree. -->

                    <!-- Health section tabs — Visible when ActiveFleetSection == Health -->
                    <local:TabControlEx x:Name="HealthTabs" Grid.Row="2"
                                Margin="8,4,8,8"
                                ItemsSource="{Binding HealthTabs}"
                                SelectedItem="{Binding SelectedHealthTab, Mode=TwoWay}"
                                Visibility="{Binding ActiveFleetSection, Converter={StaticResource FleetSectionToVis}, ConverterParameter=Health}">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource ApplicationBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                                      Padding="0,4,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                                                <ui:Button Content="+"
                                                           FontSize="16" Margin="6,0,0,0" Padding="10,2"
                                                           VerticalAlignment="Center"
                                                           Click="OnNewTab"
                                                           AutomationProperties.Name="New tab"
                                                           ToolTip="New tab (Ctrl+T)" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0">
                                        <Grid x:Name="PART_ItemsHolder" />
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabControl.ItemContainerStyle>
                            <StaticResource ResourceKey="FluentTabItemStyle" />
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            MouseLeftButtonDown="OnTabHeaderClick"
                                            MouseDown="OnTabHeaderMouseDown"
                                            ToolTip="Double-click to rename · right-click for options">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="New tab" Click="OnNewTab" InputGestureText="Ctrl+T">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Add24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Clear this tab" Click="OnClearThisTab">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Eraser24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Rename…" Click="OnRenameTab" InputGestureText="F2">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Edit24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Close tab" Click="OnCloseTab" InputGestureText="Ctrl+W">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Dismiss24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close other tabs" Click="OnCloseOtherTabs">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="DismissCircle24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close tabs to the right" Click="OnCloseTabsToRight">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowRight24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close all tabs" Click="OnCloseAllTabs">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="DismissSquare24" /></MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                    <Button Content="✕"
                                            Margin="10,0,0,0" Padding="4,0" BorderThickness="0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Click="OnCloseTab"
                                            Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"
                                            AutomationProperties.Name="Close tab"
                                            ToolTip="Close tab (Ctrl+W)">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                                    Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background"
                                                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background"
                                                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.Resources>
                            <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                                <local:WorkspaceView />
                            </DataTemplate>
                        </TabControl.Resources>
                    </local:TabControlEx>

                    <!-- Patching section tabs — Visible when ActiveFleetSection == Patching.
                         Collapsed (not removed) when Health is active — its content stays alive. -->
                    <local:TabControlEx x:Name="PatchingTabs" Grid.Row="2"
                                Margin="8,4,8,8"
                                ItemsSource="{Binding PatchingTabs}"
                                SelectedItem="{Binding SelectedPatchingTab, Mode=TwoWay}"
                                Visibility="{Binding ActiveFleetSection, Converter={StaticResource FleetSectionToVis}, ConverterParameter=Patching}">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource ApplicationBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                                      Padding="0,4,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                                                <ui:Button Content="+"
                                                           FontSize="16" Margin="6,0,0,0" Padding="10,2"
                                                           VerticalAlignment="Center"
                                                           Click="OnNewTab"
                                                           AutomationProperties.Name="New tab"
                                                           ToolTip="New tab (Ctrl+T)" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="0">
                                        <Grid x:Name="PART_ItemsHolder" />
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabControl.ItemContainerStyle>
                            <StaticResource ResourceKey="FluentTabItemStyle" />
                        </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            MouseLeftButtonDown="OnTabHeaderClick"
                                            MouseDown="OnTabHeaderMouseDown"
                                            ToolTip="Double-click to rename · right-click for options">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="New tab" Click="OnNewTab" InputGestureText="Ctrl+T">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Add24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Clear this tab" Click="OnClearThisTab">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Eraser24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Rename…" Click="OnRenameTab" InputGestureText="F2">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Edit24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Close tab" Click="OnCloseTab" InputGestureText="Ctrl+W">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="Dismiss24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close other tabs" Click="OnCloseOtherTabs">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="DismissCircle24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close tabs to the right" Click="OnCloseTabsToRight">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowRight24" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close all tabs" Click="OnCloseAllTabs">
                                                <MenuItem.Icon><ui:SymbolIcon Symbol="DismissSquare24" /></MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                                    <Button Content="✕"
                                            Margin="10,0,0,0" Padding="4,0" BorderThickness="0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                            Click="OnCloseTab"
                                            Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"
                                            AutomationProperties.Name="Close tab"
                                            ToolTip="Close tab (Ctrl+W)">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                                    Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background"
                                                                            Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background"
                                                                            Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.Resources>
                            <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                                <local:WorkspaceView />
                            </DataTemplate>
                        </TabControl.Resources>
                    </local:TabControlEx>

                    <!-- Transient completion banner (floats over the active tab). -->
                    <ui:InfoBar x:Name="CompletionBar" Grid.Row="2"
                                Margin="16,0,16,16"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="10"
                                IsOpen="False" IsClosable="True"
                                Severity="Informational"
                                Title="Operation complete"
                                Opacity="0">
                        <ui:InfoBar.Style>
                            <Style TargetType="ui:InfoBar">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOpen, RelativeSource={RelativeSource Self}}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:InfoBar.Style>
                    </ui:InfoBar>

                    <!-- Activity log resize grip -->
                    <GridSplitter x:Name="ActivitySplitter" Grid.Row="3" Height="10"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="Transparent" Cursor="SizeNS"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                                  ToolTip="Drag to resize the panel" Visibility="Collapsed">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="{TemplateBinding Background}">
                                    <Rectangle Width="40" Height="4" RadiusX="2" RadiusY="2"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Fill="{DynamicResource ControlElevationBorderBrush}" />
                                </Border>
                            </ControlTemplate>
                        </GridSplitter.Template>
                    </GridSplitter>

                    <!-- Unified bottom dock (Activity + per-machine Updates). -->
                    <Grid x:Name="ActivityPanel" Grid.Row="4" Margin="8,0,8,8" Visibility="Collapsed" Opacity="0">
                        <TabControl x:Name="BottomDockTabs" ItemContainerStyle="{StaticResource FluentTabItemStyle}">
                            <TabControl.Template>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0">
                                            <ui:Button DockPanel.Dock="Right" Margin="6,0,0,0"
                                                       VerticalAlignment="Center" Appearance="Secondary"
                                                       Icon="{ui:SymbolIcon Dismiss24}" Content="Close"
                                                       Click="OnCloseBottomDock"
                                                       AutomationProperties.Name="Close panel"
                                                       ToolTip="Close this panel" />
                                            <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                                        </DockPanel>
                                        <Border Grid.Row="1" Margin="0,4,0,0"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="0,1,0,0">
                                            <ContentPresenter ContentSource="SelectedContent" />
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </TabControl.Template>

                            <TabItem x:Name="ActivityTab" Header="Activity">
                                <Grid Margin="0,8,0,0" DataContext="{Binding ActivityLog}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" Text="Activity" FontTypography="BodyStrong" VerticalAlignment="Center" />
                                        <ui:TextBox Grid.Column="1" Margin="12,0"
                                                    PlaceholderText="Search activity (machine or text)…"
                                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Eraser24}" Content="Clear" Command="{Binding ClearCommand}" />
                                    </Grid>
                                    <Grid Grid.Row="1">
                                        <ui:DataGrid x:Name="ActivityGrid"
                                                  ItemsSource="{Binding Entries}"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  CanUserAddRows="False" HeadersVisibility="Column"
                                                  GridLinesVisibility="None"
                                                  PreviewMouseRightButtonDown="OnActivityGridRightClick">
                                            <ui:DataGrid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy" Click="OnActivityCopy">
                                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Copy24" /></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Copy all" Click="OnActivityCopyAll">
                                                        <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentCopy24" /></MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </ui:DataGrid.ContextMenu>
                                            <ui:DataGrid.Columns>
                                                <DataGridTemplateColumn Header="" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ui:SymbolIcon Margin="6,0" FontSize="14"
                                                                           Symbol="{Binding Severity, Converter={StaticResource SeveritySymbol}}"
                                                                           Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                                                                           ToolTip="{Binding Severity}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                                                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="Auto" />
                                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </ui:DataGrid.Columns>
                                        </ui:DataGrid>
                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel" BasedOn="{StaticResource EmptyStatePanel}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasEntries}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <ui:SymbolIcon Symbol="History24" FontSize="36" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Style="{StaticResource EmptyStateTitle}" Text="No activity yet" />
                                            <TextBlock Style="{StaticResource EmptyStateSubtitle}"
                                                       Text="Operations like Ping All log here as they run." />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="UpdatesTab" Header="Updates" DataContext="{Binding SelectedTab}">
                                <Grid Margin="0,8,0,0">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <ui:TextBlock Text="{Binding FocusedComputer.Name}" FontTypography="Subtitle"
                                                                  TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,4,0,0"
                                                               Visibility="{Binding IsApplicableMode, Converter={StaticResource BoolToVis}}">
                                                        <Run Text="{Binding FocusedActiveUpdates.Count, Mode=OneWay}" /><Run Text=" applicable update(s) — tick to install" /><Run Text="{Binding FocusedComputer.LastScannedApplicable, Mode=OneWay, StringFormat=' · scanned {0:t}', TargetNullValue=''}" />
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource LabelText}" Margin="0,4,0,0"
                                                               Visibility="{Binding IsInstalledMode, Converter={StaticResource BoolToVis}}">
                                                        <Run Text="{Binding FocusedActiveUpdates.Count, Mode=OneWay}" /><Run Text=" installed update(s) — tick to uninstall" /><Run Text="{Binding FocusedComputer.LastScannedInstalled, Mode=OneWay, StringFormat=' · scanned {0:t}', TargetNullValue=''}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                            IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}">
                                                    <ui:Button Content="All" Appearance="Secondary" Padding="10,2" Command="{Binding SelectAllUpdatesCommand}" />
                                                    <ui:Button Content="None" Appearance="Secondary" Padding="10,2" Margin="6,0,0,0" Command="{Binding SelectNoUpdatesCommand}" />
                                                </StackPanel>
                                                <ui:TextBox Grid.Column="1" x:Name="UpdateFilterBox" Width="220" HorizontalAlignment="Right"
                                                            Icon="{ui:SymbolIcon Search24}" ClearButtonEnabled="True"
                                                            PlaceholderText="Filter by KB or title…"
                                                            TextChanged="OnUpdateFilterChanged" />
                                            </Grid>
                                        </StackPanel>

                                        <ui:Button DockPanel.Dock="Bottom" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                   Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Install checked"
                                                   Command="{Binding InstallCheckedCommand}"
                                                   Visibility="{Binding IsApplicableMode, Converter={StaticResource BoolToVis}}"
                                                   ToolTip="Install only the ticked updates on this machine." />

                                        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,6" CornerRadius="4"
                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                BorderBrush="{DynamicResource SystemFillColorCautionBrush}" BorderThickness="1"
                                                Visibility="{Binding IsFocusedRebootPending, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12"
                                                           Text="Reboot pending. Restart before installing more." />
                                            </StackPanel>
                                        </Border>
                                        <ui:Button DockPanel.Dock="Bottom" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                   Appearance="Primary" Icon="{ui:SymbolIcon Delete24}" Content="Uninstall checked"
                                                   Click="OnUninstallChecked"
                                                   IsEnabled="{Binding CanUninstallChecked}"
                                                   Visibility="{Binding IsInstalledMode, Converter={StaticResource BoolToVis}}"
                                                   ToolTip="Uninstall the ticked updates on this machine." />

                                        <TabControl ItemContainerStyle="{StaticResource FluentSubTabItemStyle}">
                                            <TabItem Header="Applicable"
                                                     IsSelected="{Binding IsInstalledMode, Converter={StaticResource InverseBool}, Mode=TwoWay}">
                                                <Grid>
                                                    <ui:DataGrid ItemsSource="{Binding FocusedComputer.ApplicableUpdates}"
                                                                 IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}"
                                                                 AutoGenerateColumns="False" IsReadOnly="True"
                                                                 CanUserAddRows="False" CanUserDeleteRows="False"
                                                                 HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                                 SelectionMode="Single" SelectionUnit="FullRow">
                                                        <ui:DataGrid.Columns>
                                                            <DataGridTemplateColumn Width="Auto">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" />
                                                            <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="Auto" MinWidth="120">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                        <Setter Property="ToolTip" Value="{Binding Title}" />
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                            <DataGridTextColumn Header="Size" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="Auto" />
                                                        </ui:DataGrid.Columns>
                                                    </ui:DataGrid>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FocusedComputer.ApplicableUpdates.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding FocusedComputer.ApplicableMessage, TargetNullValue='Nothing here yet — scan this machine.'}"
                                                                   TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   HorizontalAlignment="Center" IsHitTestVisible="False" />
                                                        <ui:Button Margin="0,16,0,0" HorizontalAlignment="Center" Appearance="Primary"
                                                                   Icon="{ui:SymbolIcon Search24}" Content="Scan this machine"
                                                                   Command="{Binding ScanFocusedCommand}"
                                                                   ToolTip="Scan only this machine.">
                                                            <ui:Button.Style>
                                                                <Style TargetType="{x:Type ui:Button}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FocusedComputer.LastScannedApplicable}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:Button.Style>
                                                        </ui:Button>
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>
                                            <TabItem Header="Installed"
                                                     IsSelected="{Binding IsInstalledMode, Mode=TwoWay}">
                                                <Grid>
                                                    <ui:DataGrid ItemsSource="{Binding FocusedComputer.InstalledUpdates}"
                                                                 IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}"
                                                                 AutoGenerateColumns="False" IsReadOnly="True"
                                                                 CanUserAddRows="False" CanUserDeleteRows="False"
                                                                 HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                                 SelectionMode="Single" SelectionUnit="FullRow">
                                                        <ui:DataGrid.Columns>
                                                            <DataGridTemplateColumn Width="Auto">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  IsEnabled="{Binding IsUninstallable}"
                                                                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <CheckBox.Style>
                                                                                <Style TargetType="CheckBox">
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsEnabled" Value="False">
                                                                                            <Setter Property="ToolTip" Value="Neither Windows Update nor DISM can remove this update." />
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </CheckBox.Style>
                                                                        </CheckBox>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" />
                                                            <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="Auto" MinWidth="120">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                                        <Setter Property="ToolTip" Value="{Binding Title}" />
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                            <DataGridTextColumn Header="Installed" Binding="{Binding InstalledAt, StringFormat=yyyy-MM-dd}" Width="Auto" MinWidth="90" SortMemberPath="InstalledAt">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="ToolTip" Value="{Binding InstalledAt, StringFormat=F}" />
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                        </ui:DataGrid.Columns>
                                                    </ui:DataGrid>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FocusedComputer.InstalledUpdates.Count}" Value="0">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding FocusedComputer.InstalledMessage, TargetNullValue='Nothing here yet — scan this machine on the Installed tab.'}"
                                                                   TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   HorizontalAlignment="Center" IsHitTestVisible="False" />
                                                        <ui:Button Margin="0,16,0,0" HorizontalAlignment="Center" Appearance="Primary"
                                                                   Icon="{ui:SymbolIcon Search24}" Content="Scan this machine"
                                                                   Command="{Binding ScanFocusedCommand}"
                                                                   ToolTip="Scan only this machine.">
                                                            <ui:Button.Style>
                                                                <Style TargetType="{x:Type ui:Button}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding FocusedComputer.LastScannedInstalled}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:Button.Style>
                                                        </ui:Button>
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>
                                        </TabControl>
                                    </DockPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>

                </Grid>
                <!-- ═══════════════════ end COMPUTERS SECTION ═══════════════════ -->

                <!-- ════════════════════ SETTINGS SECTION ════════════════════════ -->
                <local:SettingsPage x:Name="SettingsSection" Visibility="Collapsed" />
                <!-- ════════════════════ end SETTINGS SECTION ════════════════════ -->

                <!-- ══════════════════════ SCRIPTS SECTION ═════════════════════════ -->
                <!-- Singleton keep-alive: created once here, Visibility-toggled only. -->
                <local:ScriptsPage x:Name="ScriptsSection" Visibility="Collapsed" />
                <!-- ══════════════════════ end SCRIPTS SECTION ═════════════════════ -->

                <!-- ════════════════ CROSS-DOMAIN RDP SECTION ═══════════════════ -->
                <!-- Singleton keep-alive: created once here, Visibility-toggled only — the
                     WindowsFormsHost + MSTSC ActiveX control are NEVER removed from the visual tree. -->
                <local:CrossDomainRdpView x:Name="RdpSection"
                                          DataContext="{Binding RdpViewModel}"
                                          Visibility="Collapsed" />
                <!-- ════════════════ end CROSS-DOMAIN RDP SECTION ═══════════════ -->

            </Grid>
        </Grid>

        <!-- Full-width status bar — lives at root row 2, below the nav+content row, so it never
             overlaps the nav pane. Visibility is code-controlled (UpdateStatusBarVisibility).
             During an operation (IsBusy) the center shows live narration + counts + elapsed + a slim
             progress bar along the top edge. At idle the center shows the summary text. This is the
             single progress/status surface — the toolbar ring and fleet band have been removed. -->
        <Border x:Name="StatusBar" Grid.Row="2"
                Visibility="Collapsed"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Padding="12,3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Slim progress bar along the top edge of the status bar — visible only during an operation. -->
                <ProgressBar x:Name="StatusProgressBar"
                             Grid.Row="0"
                             Minimum="0" Maximum="100"
                             Margin="0"
                             BorderThickness="0"
                             Visibility="{Binding SelectedTab.IsBusy, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" />

                <!-- Status content row -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: online summary + selection summary -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding SelectedTab.OnlineSummary}" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                        <TextBlock Text="·" Margin="10,0" Style="{StaticResource LabelText}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab.HasSelection, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding SelectedTab.SelectionSummary}" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab.HasSelection, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- Center: idle → FleetSummary; busy → SweepStatus narration + FleetNofM + FleetElapsed -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Idle summary (collapsed when busy) -->
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedTab.FleetSummary}"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab.IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Busy narration (collapsed when idle) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab.IsBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Text="{Binding SelectedTab.SweepStatus}"
                                       VerticalAlignment="Center" />
                            <TextBlock FontSize="12" Margin="10,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SelectedTab.FleetNofM}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SelectedTab.FleetNofM, Converter={StaticResource StringToVis}}" />
                            <TextBlock FontSize="12" Margin="8,0,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SelectedTab.FleetElapsed}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding SelectedTab.FleetElapsed, Converter={StaticResource StringToVis}}" />
                        </StackPanel>

                    </StackPanel>

                    <!-- Right: vitals fleet summary + activity-log toggle -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="·" Margin="10,0" Style="{StaticResource LabelText}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab.HasVitalsFleetSummary, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding SelectedTab.VitalsFleetSummary}" Style="{StaticResource LabelText}" VerticalAlignment="Center"
                                   Visibility="{Binding SelectedTab.HasVitalsFleetSummary, Converter={StaticResource BoolToVis}}" />
                        <Border Width="1" Margin="12,2,8,2" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                        <!-- Activity log toggle: opens/closes the bottom activity dock. -->
                        <ToggleButton x:Name="ActivityLogToggle"
                                      Padding="6,2"
                                      VerticalAlignment="Center"
                                      IsChecked="False"
                                      Checked="OnActivityLogToggleChanged"
                                      Unchecked="OnActivityLogToggleChanged"
                                      ToolTip="Show / hide the Activity log dock">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="History24" FontSize="14" Margin="0,0,4,0" />
                                <TextBlock Text="Activity log" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
