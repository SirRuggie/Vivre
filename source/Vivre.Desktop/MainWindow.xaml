<ui:FluentWindow x:Class="Vivre.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:updates="clr-namespace:Vivre.Core.Updates;assembly=Vivre.Core"
        mc:Ignorable="d"
        Title="Vivre"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Height="780" Width="1360"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
        <local:EnumEqualsConverter x:Key="EnumEquals" />
        <local:LogSeverityBrushConverter x:Key="SeverityBrush" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <!-- Activity log splitter + panel: hidden by default, toggled from the View menu. -->
            <RowDefinition x:Name="SplitterRow" Height="0" />
            <RowDefinition x:Name="ActivityRow" Height="0" MinHeight="0" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vivre">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.png" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- System tray icon (no visual footprint in the grid). -->
        <tb:TaskbarIcon Grid.Row="0"
                        IconSource="pack://application:,,,/Assets/AppIcon.png"
                        ToolTipText="Vivre — the heartbeat of your fleet"
                        TrayMouseDoubleClick="OnTrayOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="OnTrayOpen" />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Menu bar. File is rebuilt on open (acts on the active tab); Settings is static. -->
        <Menu Grid.Row="1" Margin="8,0,0,0" Background="Transparent">
            <MenuItem x:Name="FileMenu" Header="_File" SubmenuOpened="OnFileMenuOpened" />
            <MenuItem Header="_View">
                <MenuItem x:Name="ActivityLogMenuItem" Header="_Activity log"
                          IsCheckable="True" IsChecked="False" Click="OnToggleActivityLog" />
                <Separator />
                <MenuItem Header="_Modes">
                    <MenuItem Header="_Machines" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource InverseBool}, Mode=TwoWay}" />
                    <MenuItem Header="_Windows Update" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.IsUpdateMode, Mode=TwoWay}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Updates">
                <MenuItem Header="_Source">
                    <MenuItem Header="Windows _Update" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.WindowsUpdate}, Mode=TwoWay}" />
                    <MenuItem Header="_Microsoft Update" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.MicrosoftUpdate}, Mode=TwoWay}" />
                    <MenuItem Header="Mana_ged (WSUS/SCCM)" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.Managed}, Mode=TwoWay}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Include _drivers" IsCheckable="True"
                          IsChecked="{Binding SelectedTab.IncludeDrivers, Mode=TwoWay}"
                          ToolTip="Off (default) hides driver updates — matches the Windows Update UI and BatchPatch." />
                <Separator />
                <MenuItem Header="_Exclude updates…" Click="OnOpenExcludeDialog" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Credentials…" Click="OnOpenSettings" />
                <Separator />
                <MenuItem Header="_Theme">
                    <MenuItem Header="_Light" Click="OnThemeLight" />
                    <MenuItem Header="_Dark" Click="OnThemeDark" />
                    <MenuItem Header="_System" Click="OnThemeSystem" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Vivre" Click="OnOpenAbout" />
            </MenuItem>
        </Menu>

        <!-- Shared command bar — actions on the left, quick-add on the right. Acts on the active tab. -->
        <Grid Grid.Row="2" Margin="12,4,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- In Windows Update mode the toolbar leads with Scan + Install, separated from the machine actions. -->
                <ui:Button Icon="{ui:SymbolIcon Search24}" Content="Scan all"
                           Visibility="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource BoolToVis}}"
                           Command="{Binding SelectedTab.ScanUpdatesCommand}"
                           ToolTip="Scan every machine in this tab for updates. (To scan just one, use 'Scan this machine' in its side panel.)" />
                <ui:Button Margin="8,0,0,0" Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Install"
                           Visibility="{Binding SelectedTab.CanShowInstallToolbar, Converter={StaticResource BoolToVis}}"
                           Command="{Binding SelectedTab.InstallUpdatesCommand}"
                           ToolTip="Download + install all applicable updates (one-time SYSTEM task per host). Reboot is reported, not forced. Hidden in 'Installed' scope — uninstall is per-machine from the side panel." />
                <Border Width="1" Margin="12,4" Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Visibility="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource BoolToVis}}" />
                <ui:SplitButton Appearance="Primary"
                                Icon="{ui:SymbolIcon ArrowSync24}"
                                Content="Ping All"
                                Command="{Binding SelectedTab.PingAllCommand}">
                    <ui:SplitButton.Flyout>
                        <ContextMenu>
                            <MenuItem Header="Ping Offline only" Command="{Binding SelectedTab.PingOfflineCommand}" />
                        </ContextMenu>
                    </ui:SplitButton.Flyout>
                </ui:SplitButton>
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Heart24}" Content="Check All" Command="{Binding SelectedTab.CheckAllCommand}" />
                <ToggleButton Margin="8,0,0,0" Padding="11,6"
                              VerticalAlignment="Center"
                              IsChecked="{Binding SelectedTab.IsMonitoring, Mode=TwoWay}"
                              ToolTip="Continuously re-check online/offline for all machines. Stop halts it.">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,8,0" />
                        <TextBlock Text="Monitor" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Delete24}" Content="Remove Offline" Command="{Binding SelectedTab.RemoveOfflineCommand}" />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Stop24}" Content="Stop" Command="{Binding SelectedTab.StopCommand}" />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Eraser24}" Content="Clear Results" Command="{Binding SelectedTab.ClearResultsCommand}" />
                <ui:ProgressRing Margin="12,0,0,0" Width="22" Height="22" IsIndeterminate="True"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding SelectedTab.IsBusy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:TextBox x:Name="QuickAddBox" Width="190" PlaceholderText="Add computer…" KeyDown="OnQuickAddKeyDown" />
                <ui:Button x:Name="AddButton" Margin="6,0,0,0" Icon="{ui:SymbolIcon Add24}" Content="Add" Click="OnQuickAdd" ToolTip="Add this computer (or press Enter)" />
                <ui:Button Margin="6,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon ClipboardPaste24}" Click="OnPasteList"
                           Height="{Binding ActualHeight, ElementName=AddButton}"
                           VerticalContentAlignment="Center"
                           ToolTip="Paste a list of machines" />
            </StackPanel>
        </Grid>

        <!-- One tab per independent workspace. Header = title + close; double-click or right-click to rename.
             A browser-style "+" sits right after the last tab (TabControl template below). -->
        <TabControl Grid.Row="3"
                    Margin="8,4,8,8"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TabPanel IsItemsHost="True" />
                            <ui:Button Content="+"
                                       FontSize="16"
                                       Margin="6,0,0,0"
                                       Padding="10,2"
                                       VerticalAlignment="Center"
                                       Click="OnNewTab"
                                       ToolTip="New tab" />
                        </StackPanel>
                        <Border Grid.Row="1"
                                Margin="0,4,0,0"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal"
                                MouseLeftButtonDown="OnTabHeaderClick"
                                ToolTip="Double-click to rename · right-click for options">
                        <StackPanel.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Rename…" Click="OnRenameTab" />
                                <MenuItem Header="Close tab" Click="OnCloseTab" />
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                        <Button Content="✕"
                                Margin="10,0,0,0"
                                Padding="4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnCloseTab"
                                ToolTip="Close tab" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <local:WorkspaceView />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <GridSplitter x:Name="ActivitySplitter" Grid.Row="4" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Visibility="Collapsed" />

        <!-- Activity log (shared across all tabs) — search filters machine OR message.
             Hidden by default; shown via View ▸ Activity log. -->
        <Grid x:Name="ActivityPanel" Grid.Row="5" Margin="8,0,8,8" Visibility="Collapsed" DataContext="{Binding ActivityLog}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock Grid.Column="0" Text="Activity" FontTypography="BodyStrong" VerticalAlignment="Center" />
                <ui:TextBox Grid.Column="1" Margin="12,0"
                            PlaceholderText="Search activity (machine or text)…"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Eraser24}" Content="Clear" Command="{Binding ClearCommand}" />
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Entries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                    <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="Auto" />
                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</ui:FluentWindow>
