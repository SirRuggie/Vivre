<ui:FluentWindow x:Class="Vivre.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:updates="clr-namespace:Vivre.Core.Updates;assembly=Vivre.Core"
        mc:Ignorable="d"
        Title="Vivre"
        Icon="pack://application:,,,/Assets/AppIcon.png"
        Height="780" Width="1360"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
        <local:EnumEqualsConverter x:Key="EnumEquals" />
        <local:LogSeverityBrushConverter x:Key="SeverityBrush" />
        <local:LogSeveritySymbolConverter x:Key="SeveritySymbol" />
    </ui:FluentWindow.Resources>

    <!-- Keyboard accelerators → routed to code-behind, which forwards to the active tab's commands.
         (RoutedUICommands, not data-bound KeyBindings: InputBindings have no DataContext in WPF.) -->
    <ui:FluentWindow.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.NewTabKey}" Executed="OnNewTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.CloseTabKey}" Executed="OnCloseTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.FocusAddKey}" Executed="OnFocusAddKey" />
        <CommandBinding Command="{x:Static local:MainWindow.RenameTabKey}" Executed="OnRenameTabKey" />
        <CommandBinding Command="{x:Static local:MainWindow.ToggleModeKey}" Executed="OnToggleModeKey" />
        <CommandBinding Command="{x:Static local:MainWindow.RefreshKey}" Executed="OnRefreshKey" />
        <CommandBinding Command="{x:Static local:MainWindow.InstallKey}" Executed="OnInstallKey" />
        <CommandBinding Command="{x:Static local:MainWindow.HelpKey}" Executed="OnHelpKey" />
    </ui:FluentWindow.CommandBindings>
    <ui:FluentWindow.InputBindings>
        <KeyBinding Modifiers="Control" Key="T" Command="{x:Static local:MainWindow.NewTabKey}" />
        <KeyBinding Modifiers="Control" Key="W" Command="{x:Static local:MainWindow.CloseTabKey}" />
        <KeyBinding Modifiers="Control" Key="L" Command="{x:Static local:MainWindow.FocusAddKey}" />
        <KeyBinding Key="F2" Command="{x:Static local:MainWindow.RenameTabKey}" />
        <KeyBinding Modifiers="Control" Key="M" Command="{x:Static local:MainWindow.ToggleModeKey}" />
        <KeyBinding Key="F5" Command="{x:Static local:MainWindow.RefreshKey}" />
        <KeyBinding Modifiers="Control" Key="Return" Command="{x:Static local:MainWindow.InstallKey}" />
        <KeyBinding Key="F1" Command="{x:Static local:MainWindow.HelpKey}" />
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <!-- Fleet status band: appears only during an active update operation. -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <!-- Activity log splitter + panel: hidden by default, toggled from the View menu. -->
            <RowDefinition x:Name="SplitterRow" Height="0" />
            <RowDefinition x:Name="ActivityRow" Height="0" MinHeight="0" />
            <!-- Bottom status bar (always visible). -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vivre">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.png" Width="18" Height="18" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- System tray icon (no visual footprint in the grid). -->
        <tb:TaskbarIcon x:Name="TrayIcon" Grid.Row="0"
                        IconSource="pack://application:,,,/Assets/AppIcon.png"
                        ToolTipText="Vivre — the heartbeat of your fleet"
                        TrayMouseDoubleClick="OnTrayOpen">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="OnTrayOpen" />
                    <MenuItem Header="Exit" Click="OnTrayExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Menu bar. File is rebuilt on open (acts on the active tab); Settings is static. -->
        <Menu Grid.Row="1" Margin="8,0,0,0" Background="Transparent">
            <MenuItem x:Name="FileMenu" Header="_File" SubmenuOpened="OnFileMenuOpened" />
            <MenuItem Header="_View">
                <MenuItem x:Name="ActivityLogMenuItem" Header="_Activity log"
                          IsCheckable="True" IsChecked="False" Click="OnToggleActivityLog" />
                <Separator />
                <!-- Mode switch, directly selectable (the two are a radio pair via the inverse binding). -->
                <MenuItem Header="_Machines" IsCheckable="True"
                          IsChecked="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                          InputGestureText="Ctrl+M" />
                <MenuItem Header="_Windows Update" IsCheckable="True"
                          IsChecked="{Binding SelectedTab.IsUpdateMode, Mode=TwoWay}"
                          InputGestureText="Ctrl+M" />
            </MenuItem>
            <MenuItem Header="_Updates">
                <MenuItem Header="_Source">
                    <MenuItem Header="Windows _Update" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.WindowsUpdate}, Mode=TwoWay}" />
                    <MenuItem Header="_Microsoft Update" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.MicrosoftUpdate}, Mode=TwoWay}" />
                    <MenuItem Header="Mana_ged (WSUS/SCCM)" IsCheckable="True"
                              IsChecked="{Binding SelectedTab.SelectedSource, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static updates:UpdateSource.Managed}, Mode=TwoWay}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Include _drivers" IsCheckable="True"
                          IsChecked="{Binding SelectedTab.IncludeDrivers, Mode=TwoWay}"
                          ToolTip="Off (default) hides driver updates — matches the Windows Update UI and BatchPatch." />
                <Separator />
                <MenuItem Header="_Exclude updates…" Click="OnOpenExcludeDialog" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="_Credentials…" Click="OnOpenSettings" />
                <Separator />
                <MenuItem Header="_Theme">
                    <MenuItem x:Name="LightThemeItem" Header="_Light" IsCheckable="True" Click="OnThemeLight" />
                    <MenuItem x:Name="DarkThemeItem" Header="_Dark" IsCheckable="True" Click="OnThemeDark" />
                    <MenuItem x:Name="SystemThemeItem" Header="_System" IsCheckable="True" Click="OnThemeSystem" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_How to use Vivre…" Click="OnOpenHelp" InputGestureText="F1" />
                <Separator />
                <MenuItem Header="_About Vivre" Click="OnOpenAbout" />
            </MenuItem>
        </Menu>

        <!-- Shared command bar — actions on the left, quick-add on the right. Acts on the active tab. -->
        <Grid Grid.Row="2" Margin="12,4,12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Mode (Machines / Windows Update) is chosen from the View menu, not the toolbar.
                     Machine actions sit in a fixed position; the update-only Scan/Install append on
                     the RIGHT (below) so these buttons don't shift when you switch modes. -->
                <ui:SplitButton Appearance="Primary"
                                Icon="{ui:SymbolIcon ArrowSync24}"
                                Content="Ping All"
                                Command="{Binding SelectedTab.PingAllCommand}"
                                ToolTip="Ping every machine in this tab and update the Online status. (F5)">
                    <ui:SplitButton.Flyout>
                        <ContextMenu>
                            <MenuItem Header="Ping Offline only" Command="{Binding SelectedTab.PingOfflineCommand}" />
                        </ContextMenu>
                    </ui:SplitButton.Flyout>
                </ui:SplitButton>
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Pulse24}" Content="Check Vitals" Command="{Binding SelectedTab.CheckVitalsCommand}"
                           ToolTip="Pull SCCM client health (site, agent, reboot/updates, last boot) AND deep OS vitals (disk, memory, CPU, uptime, services, recent errors) for every machine. Read-only." />
                <ToggleButton Margin="8,0,0,0" Padding="11,6"
                              VerticalAlignment="Center"
                              IsChecked="{Binding SelectedTab.IsMonitoring, Mode=TwoWay}"
                              ToolTip="Continuously re-check online/offline for all machines. Stop halts it.">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pulse24" Margin="0,0,8,0" />
                        <TextBlock Text="Monitor" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Delete24}" Content="Remove Offline" Command="{Binding SelectedTab.RemoveOfflineCommand}"
                           ToolTip="Remove every offline (red) machine from this tab's grid. Re-paste names to bring them back." />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Stop24}" Content="Stop" Command="{Binding SelectedTab.StopCommand}"
                           ToolTip="Cancel all running operations in this tab (ping/check/scan/install)." />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Eraser24}" Content="Clear Results" Command="{Binding SelectedTab.ClearResultsCommand}"
                           ToolTip="Clear the Command result column on every row." />
                <!-- Update-only Scan + Install, appended on the right so machine buttons stay put. -->
                <Border Width="1" Margin="12,4" Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                        Visibility="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource BoolToVis}}" />
                <ui:Button Icon="{ui:SymbolIcon Search24}" Content="{Binding SelectedTab.ScanButtonLabel}"
                           Visibility="{Binding SelectedTab.IsUpdateMode, Converter={StaticResource BoolToVis}}"
                           Command="{Binding SelectedTab.ScanTargetCommand}"
                           ToolTip="Scan the selected machines (or all of them when none are selected). To scan just one, open its side panel." />
                <ui:Button x:Name="InstallButton" Margin="8,0,0,0" Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="{Binding SelectedTab.InstallButtonLabel}"
                           Visibility="{Binding SelectedTab.CanShowInstallToolbar, Converter={StaticResource BoolToVis}}"
                           IsEnabled="{Binding SelectedTab.IsBusy, Converter={StaticResource InverseBool}}"
                           Click="OnInstallClick"
                           ToolTip="Download + install applicable updates on the selected machines (or all when none selected). Asks for confirmation (Ctrl+Enter). One-time SYSTEM task per host; reboot reported, not forced. Hidden in 'Installed' scope." />
                <ui:ProgressRing Margin="12,0,0,0" Width="22" Height="22" IsIndeterminate="True"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding SelectedTab.IsBusy, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:TextBox x:Name="QuickAddBox" Width="190" PlaceholderText="Add computer…" KeyDown="OnQuickAddKeyDown" />
                <ui:Button x:Name="AddButton" Margin="6,0,0,0" Icon="{ui:SymbolIcon Add24}" Content="Add" Click="OnQuickAdd" ToolTip="Add this computer (or press Enter)" />
                <ui:Button Margin="6,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon ClipboardPaste24}" Click="OnPasteList"
                           Height="{Binding ActualHeight, ElementName=AddButton}"
                           VerticalContentAlignment="Center"
                           AutomationProperties.Name="Paste a list of machines"
                           ToolTip="Paste a list of machines" />
            </StackPanel>
        </Grid>

        <!-- Fleet status band — visible only while an update operation is running on the active tab. -->
        <Border Grid.Row="3" Margin="12,0,12,8" Padding="12,6" CornerRadius="4"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                Visibility="{Binding SelectedTab.IsPatchOperationActive, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"
                           Text="{Binding SelectedTab.FleetSummary}" />
                <ProgressBar Grid.Column="1" Height="8" VerticalAlignment="Center"
                             Minimum="0" Maximum="100" Value="{Binding SelectedTab.FleetProgress, Mode=OneWay}" />
            </Grid>
        </Border>

        <!-- One tab per independent workspace. Header = title + close; double-click or right-click to rename.
             A browser-style "+" sits right after the last tab (TabControl template below). -->
        <TabControl x:Name="WorkspaceTabs" Grid.Row="4"
                    Margin="8,4,8,8"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- "+" stays pinned at the right; the tab strip scrolls horizontally when
                             there are more tabs than fit (no clipping / off-screen "+"). -->
                        <DockPanel Grid.Row="0">
                            <ui:Button DockPanel.Dock="Right" Content="+"
                                       FontSize="16"
                                       Margin="6,0,0,0"
                                       Padding="10,2"
                                       VerticalAlignment="Center"
                                       Click="OnNewTab"
                                       AutomationProperties.Name="New tab"
                                       ToolTip="New tab (Ctrl+T)" />
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                            </ScrollViewer>
                        </DockPanel>
                        <Border Grid.Row="1"
                                Margin="0,4,0,0"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal"
                                MouseLeftButtonDown="OnTabHeaderClick"
                                ToolTip="Double-click to rename · right-click for options">
                        <StackPanel.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Rename…" Click="OnRenameTab" InputGestureText="F2" />
                                <Separator />
                                <MenuItem Header="Close tab" Click="OnCloseTab" InputGestureText="Ctrl+W" />
                                <MenuItem Header="Close other tabs" Click="OnCloseOtherTabs" />
                                <MenuItem Header="Close tabs to the right" Click="OnCloseTabsToRight" />
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                        <Button Content="✕"
                                Margin="10,0,0,0"
                                Padding="4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="OnCloseTab"
                                AutomationProperties.Name="Close tab"
                                ToolTip="Close tab (Ctrl+W)" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <local:WorkspaceView />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- Transient "operation finished" banner — shown in-window when a Scan/Install/Uninstall
             completes while the window is focused (the tray balloon covers the unfocused case).
             Auto-closes after a few seconds; floats over the bottom of the active tab. -->
        <ui:InfoBar x:Name="CompletionBar" Grid.Row="4"
                    Margin="16,0,16,16"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="10"
                    IsOpen="False" IsClosable="True"
                    Severity="Informational"
                    Title="Operation complete" />

        <GridSplitter x:Name="ActivitySplitter" Grid.Row="5" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Visibility="Collapsed" />

        <!-- Unified bottom dock (shared across all tabs): an Activity tab + a per-machine Updates
             tab, with a Close button to dismiss the whole dock. Hidden by default; opened via the
             View ▸ Activity log menu OR when a machine is focused in Windows Update mode. -->
        <Grid x:Name="ActivityPanel" Grid.Row="6" Margin="8,0,8,8" Visibility="Collapsed">
            <TabControl x:Name="BottomDockTabs">
                <!-- Close button floats over the tab strip, on the right. -->
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0">
                                <ui:Button DockPanel.Dock="Right"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Dismiss24}"
                                           Content="Close"
                                           Click="OnCloseBottomDock"
                                           AutomationProperties.Name="Close panel"
                                           ToolTip="Close this panel (gives the grid the full window height back)" />
                                <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                            </DockPanel>
                            <Border Grid.Row="1"
                                    Margin="0,4,0,0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- Activity tab (always present). Its content root keeps the ActivityLog DataContext. -->
                <TabItem x:Name="ActivityTab" Header="Activity">
                    <Grid Margin="0,8,0,0" DataContext="{Binding ActivityLog}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBlock Grid.Column="0" Text="Activity" FontTypography="BodyStrong" VerticalAlignment="Center" />
                            <ui:TextBox Grid.Column="1" Margin="12,0"
                                        PlaceholderText="Search activity (machine or text)…"
                                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Eraser24}" Content="Clear" Command="{Binding ClearCommand}" />
                        </Grid>

                        <DataGrid Grid.Row="1" x:Name="ActivityGrid"
                                  ItemsSource="{Binding Entries}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  PreviewMouseRightButtonDown="OnActivityGridRightClick">
                            <!-- Right-click selects the line under the cursor (handled at grid level so we don't
                                 override the themed row style), then the context menu copies it. -->
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy" Click="OnActivityCopy" />
                                    <MenuItem Header="Copy all" Click="OnActivityCopyAll" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ui:SymbolIcon Margin="6,0" FontSize="14"
                                                           Symbol="{Binding Severity, Converter={StaticResource SeveritySymbol}}"
                                                           Foreground="{Binding Severity, Converter={StaticResource SeverityBrush}}"
                                                           ToolTip="{Binding Severity}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="Auto" />
                                <DataGridTextColumn Header="Machine" Binding="{Binding Machine}" Width="Auto" />
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Updates tab (relocated per-machine update detail). Only visible/selectable when a
                     machine is focused in Windows Update mode; otherwise the TabItem is collapsed.
                     Its content root sets the active tab's WorkspaceViewModel as DataContext so all the
                     panel's existing bindings resolve unchanged. -->
                <TabItem x:Name="UpdatesTab" Header="Updates" DataContext="{Binding SelectedTab}">
                    <Grid Margin="0,8,0,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,4,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding FocusedComputer.Name}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <!-- Scope is chosen by the Applicable / Installed tabs below. -->

                                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"
                                                   Visibility="{Binding IsApplicableMode, Converter={StaticResource BoolToVis}}">
                                            <Run Text="{Binding FocusedActiveUpdates.Count, Mode=OneWay}" /><Run Text=" applicable update(s) — tick to install" /><Run Text="{Binding FocusedComputer.LastScannedApplicable, Mode=OneWay, StringFormat=' · scanned {0:t}', TargetNullValue=''}" />
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"
                                                   Visibility="{Binding IsInstalledMode, Converter={StaticResource BoolToVis}}">
                                            <Run Text="{Binding FocusedActiveUpdates.Count, Mode=OneWay}" /><Run Text=" installed update(s) — tick to uninstall" /><Run Text="{Binding FocusedComputer.LastScannedInstalled, Mode=OneWay, StringFormat=' · scanned {0:t}', TargetNullValue=''}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}">
                                        <ui:Button Content="All" Appearance="Secondary" Padding="10,2" Command="{Binding SelectAllUpdatesCommand}" />
                                        <ui:Button Content="None" Appearance="Secondary" Padding="10,2" Margin="6,0,0,0" Command="{Binding SelectNoUpdatesCommand}" />
                                    </StackPanel>
                                    <ui:TextBox Grid.Column="1" x:Name="UpdateFilterBox" Width="220" HorizontalAlignment="Right"
                                                Icon="{ui:SymbolIcon Search24}" ClearButtonEnabled="True"
                                                PlaceholderText="Filter by KB or title…"
                                                TextChanged="OnUpdateFilterChanged" />
                                </Grid>
                            </StackPanel>

                            <ui:Button DockPanel.Dock="Bottom" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                       Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Install checked"
                                       Command="{Binding InstallCheckedCommand}"
                                       Visibility="{Binding IsApplicableMode, Converter={StaticResource BoolToVis}}"
                                       ToolTip="Install only the ticked updates on this machine (one-time SYSTEM task). Reboot is reported, not forced. Disabled while a reboot is pending — restart first." />

                            <!-- Reboot-pending warning: after an install WUA still reports the just-installed
                                 update as applicable until the reboot finalizes it. Restart before installing
                                 more (and the agent would defer an install on a reboot-pending box anyway). -->
                            <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,6" CornerRadius="4"
                                    Background="#33D9A300" BorderBrush="#D9A300" BorderThickness="1"
                                    Visibility="{Binding IsFocusedRebootPending, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12"
                                               Text="Reboot pending. Just-installed updates may still show as applicable until you restart — reboot this machine before installing more." />
                                </StackPanel>
                            </Border>
                            <ui:Button DockPanel.Dock="Bottom" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                       Appearance="Primary" Icon="{ui:SymbolIcon Delete24}" Content="Uninstall checked"
                                       Click="OnUninstallChecked"
                                       IsEnabled="{Binding CanUninstallChecked}"
                                       Visibility="{Binding IsInstalledMode, Converter={StaticResource BoolToVis}}"
                                       ToolTip="Uninstall the ticked updates on this machine (Windows Update first, then DISM). Greyed rows can't be removed by either. May require a reboot. Disabled until at least one removable update is ticked." />

                            <TabControl>
                                <TabItem Header="Applicable"
                                         IsSelected="{Binding IsInstalledMode, Converter={StaticResource InverseBool}, Mode=TwoWay}">
                                    <Grid>
                                        <ui:DataGrid ItemsSource="{Binding FocusedComputer.ApplicableUpdates}"
                                                     IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}"
                                                     AutoGenerateColumns="False" IsReadOnly="True"
                                                     CanUserAddRows="False" CanUserDeleteRows="False"
                                                     HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                     SelectionMode="Single" SelectionUnit="FullRow">
                                            <ui:DataGrid.Columns>
                                                <DataGridTemplateColumn Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" />
                                                <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="Auto" MinWidth="120">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                            <Setter Property="ToolTip" Value="{Binding Title}" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="Auto" />
                                            </ui:DataGrid.Columns>
                                        </ui:DataGrid>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FocusedComputer.ApplicableUpdates.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="{Binding FocusedComputer.ApplicableMessage, TargetNullValue='Nothing here yet — scan this machine.'}"
                                                       TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" IsHitTestVisible="False" />
                                            <ui:Button Margin="0,16,0,0" HorizontalAlignment="Center" Appearance="Primary"
                                                       Icon="{ui:SymbolIcon Search24}" Content="Scan this machine"
                                                       Command="{Binding ScanFocusedCommand}"
                                                       ToolTip="Scan only this machine. The toolbar Scan (top bar) scans every machine in the tab.">
                                                <ui:Button.Style>
                                                    <Style TargetType="{x:Type ui:Button}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FocusedComputer.LastScannedApplicable}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Installed"
                                         IsSelected="{Binding IsInstalledMode, Mode=TwoWay}">
                                    <Grid>
                                        <ui:DataGrid ItemsSource="{Binding FocusedComputer.InstalledUpdates}"
                                                     IsEnabled="{Binding IsFocusedPatching, Converter={StaticResource InverseBool}}"
                                                     AutoGenerateColumns="False" IsReadOnly="True"
                                                     CanUserAddRows="False" CanUserDeleteRows="False"
                                                     HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                     SelectionMode="Single" SelectionUnit="FullRow">
                                            <ui:DataGrid.Columns>
                                                <DataGridTemplateColumn Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding IsUninstallable}"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="CheckBox">
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="ToolTip" Value="Neither Windows Update nor DISM can remove this update." />
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" />
                                                <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="Auto" MinWidth="120">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                            <Setter Property="ToolTip" Value="{Binding Title}" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Installed" Binding="{Binding InstalledAt, StringFormat=yyyy-MM-dd}" Width="Auto" MinWidth="90" SortMemberPath="InstalledAt">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="ToolTip" Value="{Binding InstalledAt, StringFormat=F}" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                            </ui:DataGrid.Columns>
                                        </ui:DataGrid>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FocusedComputer.InstalledUpdates.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="{Binding FocusedComputer.InstalledMessage, TargetNullValue='Nothing here yet — scan this machine on the Installed tab.'}"
                                                       TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center" IsHitTestVisible="False" />
                                            <ui:Button Margin="0,16,0,0" HorizontalAlignment="Center" Appearance="Primary"
                                                       Icon="{ui:SymbolIcon Search24}" Content="Scan this machine"
                                                       Command="{Binding ScanFocusedCommand}"
                                                       ToolTip="Scan only this machine. The toolbar Scan (top bar) scans every machine in the tab.">
                                                <ui:Button.Style>
                                                    <Style TargetType="{x:Type ui:Button}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FocusedComputer.LastScannedInstalled}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Button.Style>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Bottom status bar: live online/total + update tally for the active tab. (Copy actions
             live in the grid's right-click Copy ▸ menu.) -->
        <Border Grid.Row="7"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Padding="12,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding SelectedTab.OnlineSummary}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="·" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedTab.HasSelection, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding SelectedTab.SelectionSummary}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedTab.HasSelection, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="·" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedTab.HasFleetSummary, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding SelectedTab.FleetSummary}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="·" Margin="10,0" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedTab.HasVitalsFleetSummary, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding SelectedTab.VitalsFleetSummary}" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedTab.HasVitalsFleetSummary, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
