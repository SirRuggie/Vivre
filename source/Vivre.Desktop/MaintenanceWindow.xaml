<ui:FluentWindow x:Class="Vivre.Desktop.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Vivre.Desktop"
        mc:Ignorable="d"
        Title="WhatsUp Gold maintenance"
        Height="600" Width="520"
        MinHeight="480" MinWidth="460"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="WhatsUp Gold maintenance"
                     Icon="{ui:SymbolIcon Wrench24}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,0">
            <StackPanel>
                <ui:TextBlock x:Name="Intro" Appearance="Secondary" TextWrapping="Wrap" Margin="0,0,0,16" />

                <ui:TextBlock Text="Maintenance" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <RadioButton x:Name="EnterRadio" GroupName="Mode" Content="Enter — suppress alerts"
                                 IsChecked="True" Margin="0,0,20,0" Checked="OnModeChanged" />
                    <RadioButton GroupName="Mode" Content="Exit — resume monitoring" Checked="OnModeChanged" />
                </StackPanel>

                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,12" />
                <ui:TextBlock Text="WhatsUp Gold server" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <ui:TextBox x:Name="ServerBox" Margin="0,0,0,12" />

                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,12" />
                <ui:TextBlock Text="WhatsUp Gold username" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <ui:TextBox x:Name="UserBox" PlaceholderText="domain\user or user" Margin="0,0,0,12" />

                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,12" />
                <ui:TextBlock Text="WhatsUp Gold password" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBox" Height="32" VerticalContentAlignment="Center" Margin="0,0,0,12" />

                <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,12" />
                <ui:TextBlock Text="Reason" FontTypography="BodyStrong" Margin="0,0,0,4" />
                <ui:TextBox x:Name="ReasonBox" Margin="0,0,0,4" />
            </StackPanel>
        </ScrollViewer>

        <!-- Result / error: a read-only box so it's always visible AND selectable (copyable). -->
        <TextBox Grid.Row="2" x:Name="StatusText"
                 Margin="24,8,24,0"
                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 BorderThickness="0" Background="Transparent"
                 MaxHeight="120" VerticalScrollBarVisibility="Auto"
                 Visibility="Collapsed" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,16">
            <ui:Button x:Name="RunButton" Appearance="Primary" Content="Set maintenance" Click="OnRun" IsDefault="True" />
            <ui:Button Margin="8,0,0,0" Content="Close" Click="OnClose" IsCancel="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
