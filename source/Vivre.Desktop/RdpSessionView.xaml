<UserControl x:Class="Vivre.Desktop.RdpSessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <!-- DockPanel: status strip docked top (hidden once connected), the host fills the rest. The host is
         wrapped in a Grid (HostContainer) whose size we read to size the WindowsFormsHost explicitly —
         WindowsFormsHost ignores Stretch and otherwise collapses to the hosted control's default size. -->
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="10,6"
                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                Visibility="{Binding ShowStatusBar, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:ProgressRing Width="18" Height="18" IsIndeterminate="True" Margin="0,0,10,0"
                                 Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" TextWrapping="Wrap" />
                <ui:Button Content="Reconnect" Margin="12,0,0,0" Click="OnReconnect"
                           Visibility="{Binding CanReconnect, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <Grid x:Name="HostContainer" SizeChanged="OnHostContainerSizeChanged">
            <wfi:WindowsFormsHost x:Name="RdpHostElement" />
        </Grid>
    </DockPanel>
</UserControl>
