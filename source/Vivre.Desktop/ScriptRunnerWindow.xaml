<ui:FluentWindow x:Class="Vivre.Desktop.ScriptRunnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Run Script"
        Height="660" Width="940"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!-- Group the saved-scripts list by category folder, like the right-click menu. -->
        <CollectionViewSource x:Key="GroupedScripts" Source="{Binding Scripts}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </ui:FluentWindow.Resources>

    <Grid Margin="0,0,0,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Run Script" />

        <ui:TextBlock Grid.Row="1"
                      Margin="24,4,24,8"
                      Appearance="Secondary"
                      Text="{Binding TargetSummary}" />

        <!-- Saved scripts (left) + editor (right) -->
        <Grid Grid.Row="2" Margin="24,0,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <ui:ListView x:Name="ScriptList"
                         Grid.Column="0"
                         ItemsSource="{Binding Source={StaticResource GroupedScripts}}"
                         SelectedItem="{Binding SelectedScript, Mode=TwoWay}"
                         SelectionChanged="OnScriptSelected"
                         DisplayMemberPath="Name"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ui:ListView.GroupStyle>
                    <GroupStyle>
                        <!-- Each category is a collapsible Expander (name + count); starts collapsed. -->
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <!-- M28: animated chevron — RotateTransform eases to 0° on expand (150ms). -->
                                            <Expander IsExpanded="False">
                                                <Expander.Template>
                                                    <ControlTemplate TargetType="Expander">
                                                        <StackPanel>
                                                            <!-- Toggle button: CheckBox-less ToggleButton hosts the arrow + header.
                                                                 IsChecked mirrors IsExpanded so the ControlTemplate trigger fires. -->
                                                            <ToggleButton x:Name="Toggler"
                                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                                                      RelativeSource={RelativeSource AncestorType=Expander}}"
                                                                          Background="Transparent" BorderThickness="0"
                                                                          Padding="2,4" Cursor="Hand"
                                                                          HorizontalContentAlignment="Left">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Path x:Name="Arrow"
                                                                                      Data="M0,0 L4,4 L8,0"
                                                                                      Width="8" Height="5"
                                                                                      Stroke="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                      StrokeThickness="1.5"
                                                                                      VerticalAlignment="Center"
                                                                                      Margin="0,0,6,0"
                                                                                      RenderTransformOrigin="0.5,0.5">
                                                                                    <Path.RenderTransform>
                                                                                        <RotateTransform x:Name="ArrowRotation" Angle="-90" />
                                                                                    </Path.RenderTransform>
                                                                                </Path>
                                                                                <ContentPresenter VerticalAlignment="Center" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation
                                                                                                Storyboard.TargetName="ArrowRotation"
                                                                                                Storyboard.TargetProperty="Angle"
                                                                                                To="0" Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut" />
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation
                                                                                                Storyboard.TargetName="ArrowRotation"
                                                                                                Storyboard.TargetProperty="Angle"
                                                                                                To="-90" Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut" />
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                                <ContentPresenter ContentSource="Header" />
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="ExpanderContent"
                                                                              ContentSource="Content"
                                                                              Visibility="Collapsed" />
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsExpanded" Value="True">
                                                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Expander.Template>
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding Name}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Name}" Value="">
                                                                            <Setter Property="Text" Value="General" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" Opacity="0.6" />
                                                    </StackPanel>
                                                </Expander.Header>
                                                <ItemsPresenter />
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ui:ListView.GroupStyle>
            </ui:ListView>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ToolTip="Drag to resize" />

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <avalon:TextEditor x:Name="Editor"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="13"
                                   Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Padding="6" />
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Save current editor content into a folder (pick one or type a new name to create it) -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <ComboBox Width="150"
                          IsEditable="True"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding Categories}"
                          Text="{Binding SaveCategory, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Folder to save into — pick one or type a new name to create it" />
                <ui:TextBox x:Name="NameBox"
                            Width="200"
                            Margin="8,0,0,0"
                            PlaceholderText="Script name"
                            Text="{Binding ScriptName, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Save24}"
                           Content="Save"
                           Click="OnSave" />
                <ui:Button Margin="8,0,0,0"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Delete24}"
                           Content="Delete"
                           Click="OnDeleteScript"
                           IsEnabled="{Binding CanDeleteSelectedScript}"
                           ToolTip="Delete the selected saved script (built-in scripts can't be deleted)" />
            </StackPanel>

            <!-- Run / Stop -->
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <ui:ProgressRing Width="22" Height="22" Margin="0,0,8,0"
                                 IsIndeterminate="True"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <ui:Button Appearance="Primary"
                           Icon="{ui:SymbolIcon Play24}"
                           Content="Run"
                           IsEnabled="{Binding CanRun}"
                           Click="OnRun" />
                <ui:Button Margin="8,0,0,0"
                           Icon="{ui:SymbolIcon Stop24}"
                           Content="Stop"
                           Command="{Binding RunCancelCommand}" />
            </StackPanel>
        </Grid>

        <!-- Output (auto-scrolls to newest line) -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:TextBlock Grid.Row="0" FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Text="Output" Margin="24,8,24,4" />
            <Border Grid.Row="1" Margin="24,0,24,0"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <TextBox x:Name="OutputBox"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Padding="6"
                         TextChanged="OnOutputChanged"
                         Text="{Binding Output, Mode=OneWay}" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
