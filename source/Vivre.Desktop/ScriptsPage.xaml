<UserControl x:Class="Vivre.Desktop.ScriptsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Group the script list by category folder, same as ScriptRunnerWindow. -->
        <CollectionViewSource x:Key="GroupedScripts" Source="{Binding Scripts}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid Margin="12,8,12,12">
        <Grid.RowDefinitions>
            <!-- Heading -->
            <RowDefinition Height="Auto" />
            <!-- List + Editor (stretch) -->
            <RowDefinition Height="*" />
            <!-- Save / Delete toolbar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page heading -->
        <ui:TextBlock Grid.Row="0" FontTypography="Title" Text="Scripts" Margin="0,0,0,12" />

        <!-- Left: category-grouped script list   Right: AvalonEdit editor -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- ── Script list with category Expanders ───────────────────── -->
            <ui:ListView x:Name="ScriptList"
                         Grid.Column="0"
                         ItemsSource="{Binding Source={StaticResource GroupedScripts}}"
                         SelectedItem="{Binding SelectedScript, Mode=TwoWay}"
                         SelectionChanged="OnScriptSelected"
                         DisplayMemberPath="Name"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ui:ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander IsExpanded="False">
                                                <Expander.Template>
                                                    <ControlTemplate TargetType="Expander">
                                                        <StackPanel>
                                                            <ToggleButton x:Name="Toggler"
                                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                                                      RelativeSource={RelativeSource AncestorType=Expander}}"
                                                                          Background="Transparent" BorderThickness="0"
                                                                          Padding="2,4" Cursor="Hand"
                                                                          HorizontalContentAlignment="Left">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Path x:Name="Arrow"
                                                                                      Data="M0,0 L4,4 L8,0"
                                                                                      Width="8" Height="5"
                                                                                      Stroke="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                      StrokeThickness="1.5"
                                                                                      VerticalAlignment="Center"
                                                                                      Margin="0,0,6,0"
                                                                                      RenderTransformOrigin="0.5,0.5">
                                                                                    <Path.RenderTransform>
                                                                                        <RotateTransform x:Name="ArrowRotation" Angle="-90" />
                                                                                    </Path.RenderTransform>
                                                                                </Path>
                                                                                <ContentPresenter VerticalAlignment="Center" />
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation
                                                                                                Storyboard.TargetName="ArrowRotation"
                                                                                                Storyboard.TargetProperty="Angle"
                                                                                                To="0" Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut" />
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard>
                                                                                        <Storyboard>
                                                                                            <DoubleAnimation
                                                                                                Storyboard.TargetName="ArrowRotation"
                                                                                                Storyboard.TargetProperty="Angle"
                                                                                                To="-90" Duration="0:0:0.15">
                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                    <CubicEase EasingMode="EaseOut" />
                                                                                                </DoubleAnimation.EasingFunction>
                                                                                            </DoubleAnimation>
                                                                                        </Storyboard>
                                                                                    </BeginStoryboard>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                                <ContentPresenter ContentSource="Header" />
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="ExpanderContent"
                                                                              ContentSource="Content"
                                                                              Visibility="Collapsed" />
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsExpanded" Value="True">
                                                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Expander.Template>
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding Name}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Name}" Value="">
                                                                            <Setter Property="Text" Value="General" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" Opacity="0.6" />
                                                    </StackPanel>
                                                </Expander.Header>
                                                <ItemsPresenter />
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ui:ListView.GroupStyle>
            </ui:ListView>

            <!-- Resize grip -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ToolTip="Drag to resize" />

            <!-- ── AvalonEdit editor ────────────────────────────────────── -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <avalon:TextEditor x:Name="Editor"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="13"
                                   Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Padding="6" />
            </Border>
        </Grid>

        <!-- ── Add / Save / Delete toolbar ──────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">

            <!-- Add — clears editor + name for a new entry. -->
            <ui:Button Icon="{ui:SymbolIcon Add24}"
                       Content="Add"
                       Click="OnAdd"
                       ToolTip="Clear the editor for a new script" />

            <Border Width="1" Margin="12,4"
                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

            <!-- Category picker and name box for Save -->
            <ComboBox x:Name="CategoryCombo"
                      Width="150"
                      IsEditable="True"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding Categories}"
                      Text="{Binding SaveCategory, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Category (folder) — pick one or type a new name to create it" />

            <ui:TextBox x:Name="NameBox"
                        Width="200"
                        Margin="8,0,0,0"
                        PlaceholderText="Script name"
                        Text="{Binding ScriptName, UpdateSourceTrigger=PropertyChanged}" />

            <ui:Button Margin="8,0,0,0"
                       Icon="{ui:SymbolIcon Save24}"
                       Content="Save"
                       Click="OnSave"
                       ToolTip="Save the editor content under this name and category" />

            <ui:Button Margin="8,0,0,0"
                       Appearance="Secondary"
                       Icon="{ui:SymbolIcon Delete24}"
                       Content="Delete"
                       Click="OnDelete"
                       IsEnabled="{Binding CanDeleteSelectedScript}"
                       ToolTip="Delete the selected script (built-in scripts cannot be deleted)" />
        </StackPanel>
    </Grid>
</UserControl>
