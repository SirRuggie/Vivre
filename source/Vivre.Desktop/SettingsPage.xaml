<UserControl x:Class="Vivre.Desktop.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Vivre.Desktop"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:InverseBooleanConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,16,24,24" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Page heading -->
            <ui:TextBlock FontTypography="Title" Text="Settings" Margin="0,0,0,20" />

            <!-- ── Appearance (flat row) ──────────────────────────────────── -->
            <Border Padding="16" CornerRadius="6" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Appearance" Margin="0,0,0,12" />
                    <!-- Task-Manager-style settings row: icon | title+subtitle | combo -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Color24" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="App theme" />
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Select which app theme to display" />
                        </StackPanel>
                        <ComboBox Grid.Column="2" x:Name="ThemeCombo" MinWidth="160"
                                  VerticalAlignment="Center"
                                  SelectionChanged="OnThemeComboChanged">
                            <ComboBoxItem Content="Use system setting" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Fleet behavior (flat card: auto-check + grid columns) ───── -->
            <Border Padding="16" CornerRadius="6" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel>
                    <ui:TextBlock FontTypography="BodyStrong" Text="Fleet behavior" Margin="0,0,0,12" />

                    <!-- Auto-check on load row (moved verbatim) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Pulse24" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="Auto-check on load" />
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                          Text="When on, loading a list auto-pings and checks vitals. When off, the grid is a frozen snapshot until you click Ping All or Check Vitals." />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="2" x:Name="AutoToggle"
                                         VerticalAlignment="Center" Margin="16,0,0,0"
                                         Checked="OnAutoCheckChanged"
                                         Unchecked="OnAutoCheckChanged"
                                         ToolTip="On (default): loading a list auto-pings + checks vitals on those machines. Off: manual — a frozen snapshot until you click Ping All / Check Vitals." />
                    </Grid>

                    <!-- Grid columns row (moved verbatim) -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Table24" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock Text="Grid columns" />
                            <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                          Text="Show or hide built-in columns; add custom PowerShell columns." />
                        </StackPanel>
                        <ui:Button Grid.Column="2" Content="Manage columns…"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   Click="OnOpenColumns"
                                   ToolTip="Show / hide built-in columns and manage custom PowerShell columns." />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Remote credentials (collapsed expander) ──────────────────── -->
            <ui:CardExpander x:Name="CredentialCard" Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Key24}"
                             Header="Remote credentials">
                <StackPanel Margin="0,8,0,0">
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                  Text="Used to reach your machines — for health checks, patching, Run Script, SCCM client actions, and Enable WinRM. Held for this session only — never saved to disk." />

                    <RadioButton x:Name="UseLoginRadio"
                                 Content="Use my Windows login"
                                 IsChecked="{Binding UseExplicitCredentials, Converter={StaticResource InverseBool}}"
                                 Margin="0,0,0,6" />
                    <RadioButton x:Name="UseExplicitRadio"
                                 Content="Use these credentials"
                                 IsChecked="{Binding UseExplicitCredentials}" />

                    <Grid Margin="24,10,0,0" IsEnabled="{Binding UseExplicitCredentials}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ui:TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8" Text="Domain" />
                        <ui:TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                                      PlaceholderText="e.g. EMPLOYEES"
                                      Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}" />

                        <ui:TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8" Text="Username" />
                        <ui:TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" x:Name="UserNameBox"
                                      PlaceholderText="e.g. admin_sbridges"
                                      Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                        <ui:TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8" Text="Password" />
                        <PasswordBox  Grid.Row="2" Grid.Column="1" x:Name="PasswordBox"
                                      Height="32" VerticalContentAlignment="Center" Margin="0,0,0,8" />

                        <ui:Button Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left"
                                   Appearance="Primary" Content="Apply"
                                   Click="OnApplyCredentials" />
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

            <!-- ── WhatsUp Gold (collapsed expander) ─────────────────────── -->
            <ui:CardExpander Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Link24}"
                             Header="WhatsUp Gold">
                <StackPanel Margin="0,8,0,0">

                    <!-- WhatsUp Gold server (moved verbatim) -->
                    <ui:TextBlock Text="WhatsUp Gold server" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="WugServerBox"
                                PlaceholderText="e.g. 10.70.25.111"
                                LostFocus="OnWugServerChanged"
                                Margin="0,0,0,4" />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"
                                  Text="Used by right-click ▸ WhatsUp Gold maintenance… (set) and ▸ Check WhatsUp Gold state… (read) for monitoring maintenance. Hostname or IP; connects over HTTPS with the credentials you enter in that dialog." />

                    <!-- State check — simultaneous lookups (reformatted from the flat row) -->
                    <ui:TextBlock Text="State check — simultaneous lookups" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="WugStateConcurrencyBox"
                                MinWidth="70" HorizontalAlignment="Left"
                                PlaceholderText="2"
                                LostFocus="OnWugStateConcurrencyChanged"
                                Margin="0,0,0,4"
                                ToolTip="How many WUG devices the state check queries at once (1–4). Default 2." />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                  Text="How many WUG devices the state check queries at once. Measured on the live server: 2 is the sweet spot — more just loads the WUG server for no extra speed. Range 1–4; default 2. Takes effect on the next check." />

                </StackPanel>
            </ui:CardExpander>

            <!-- ── Software staging (collapsed expander) ─────────────────── -->
            <ui:CardExpander Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Folder24}"
                             Header="Software staging">
                <StackPanel Margin="0,8,0,0">

                    <!-- Package library folder (moved verbatim) -->
                    <ui:TextBlock Text="Package library folder" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" x:Name="PackagesFolderBox"
                                    PlaceholderText="e.g. \\server\packages"
                                    LostFocus="OnPackagesFolderChanged"
                                    Margin="0,0,8,0" />
                        <ui:Button Grid.Column="1" Content="Browse…"
                                   Click="OnBrowsePackagesFolder"
                                   ToolTip="Pick the package library folder." />
                    </Grid>
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                  Text="Source library for right-click ▸ Software ▸ Stage software… — each subfolder or file here becomes a stageable package. Local or UNC path (e.g. \\server\packages). This is where packages come from, not where they're delivered." />

                </StackPanel>
            </ui:CardExpander>

            <!-- ── Patching ──────────────────────────────────────────────── -->
            <ui:TextBlock FontTypography="BodyStrong" Text="Patching" Margin="0,12,0,8" />

            <!-- ── Max simultaneous installs (flat row) ─────────────────── -->
            <Border Padding="16" CornerRadius="6" Margin="0,0,0,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Grid.Column="0" Symbol="ArrowDownload24" FontSize="20"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <ui:TextBlock Text="Max simultaneous installs" />
                        <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                      Text="How many machines install, uninstall, stage, or clean up at once. The practical limit is download bandwidth. Range 1–200; default 50. Takes effect on the next install sweep — in-flight sweeps are not interrupted." />
                    </StackPanel>
                    <ui:TextBox Grid.Column="2" x:Name="MaxInstallsBox"
                                MinWidth="70" VerticalAlignment="Center" Margin="16,0,0,0"
                                PlaceholderText="50"
                                LostFocus="OnMaxInstallsChanged"
                                ToolTip="Cap on simultaneous installs/uninstalls/stages (1–200). Default 50." />
                </Grid>
            </Border>

            <!-- ── Server 2016 cumulative update (collapsed expander) ──────── -->
            <ui:CardExpander Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Box24}"
                             Header="Server 2016 cumulative update">
                <StackPanel Margin="0,8,0,0">
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                  Text="Each month, tell Vivre which Server 2016 update you're rolling out: its KB number and the build number servers should show once it's installed. You download the update file (.msu) from the Microsoft Update Catalog into the folder below yourself — Vivre never downloads it." />

                    <!-- KB number -->
                    <ui:TextBlock Text="KB number" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="LcuKbBox"
                                PlaceholderText="e.g. KB5094122"
                                LostFocus="OnLcuKbChanged"
                                Margin="0,0,0,4" />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                  Text="This month's update number, e.g. KB5094122 — it's in the update's title on the catalog and history pages below. Vivre uses it to find the .msu in the package folder and shows it in the 2016 panel." />

                    <!-- Build number after the update -->
                    <ui:TextBlock Text="Build number after the update" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="LcuUbrBox"
                                PlaceholderText="e.g. 9234"
                                LostFocus="OnLcuUbrChanged"
                                Margin="0,0,0,4" />
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                  Text="After the update installs, servers should report OS Build 14393.XXXX — enter just the XXXX part (e.g. 9339). It's listed beside the KB on the update history page. Verify and the Reboot Wave compare servers against this number (it's also called the target UBR)." />

                    <!-- Find this month's update — read-only, selectable link. -->
                    <ui:TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                  Text="Find this month's update (Microsoft Update Catalog):" />
                    <TextBox Text="https://catalog.update.microsoft.com/Search.aspx?q=Cumulative+Update+for+Windows+Server+2016+for+x64-based+Systems"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"
                             Margin="0,0,0,12"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             ToolTip="Read-only — select the text to copy the link." />

                    <!-- Find the build number — read-only, selectable link. -->
                    <ui:TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                                  Text="Find the build number (update history page):" />
                    <TextBox Text="https://support.microsoft.com/en-us/help/4000825"
                             IsReadOnly="True" BorderThickness="0" Background="Transparent" Padding="0"
                             Margin="0,0,0,12"
                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                             ToolTip="Read-only — select the text to copy the link." />

                    <!-- Architecture (fixed) -->
                    <ui:TextBlock Text="Architecture" Margin="0,0,0,4" />
                    <ui:TextBlock Text="x64" Margin="0,0,0,12"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- CU package folder -->
                    <ui:TextBlock Text="CU package folder" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" x:Name="LcuPackagesFolderBox"
                                    PlaceholderText="e.g. C:\Vivre\VivrePackages"
                                    LostFocus="OnLcuPackagesFolderChanged"
                                    Margin="0,0,8,0" />
                        <ui:Button Grid.Column="1" Content="Browse…"
                                   Click="OnBrowseLcuPackagesFolder"
                                   ToolTip="Pick the folder you drop the monthly .msu into." />
                    </Grid>
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                                  Text="Where you drop the monthly cumulative-update .msu downloaded from the Microsoft Update Catalog. Default: C:\Vivre\VivrePackages. Vivre only reads from here — it never downloads the file itself." />
                </StackPanel>
            </ui:CardExpander>

            <!-- ── Staged patching machines (collapsed expander) ──────────── -->
            <ui:CardExpander Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Box24}"
                             Header="Staged patching machines"
                             Expanded="OnStagedHostsExpanded">
                <StackPanel Margin="0,8,0,0">
                    <ui:TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                  Text="Server 2016 machines you've flagged to patch through the DISM staging lane instead of normal Windows Update. Flag one by right-clicking its row in a Patching tab ▸ Mark as Staged patching. Remove a machine here to send it back to normal Windows Update." />

                    <ListBox x:Name="StagedHostsList" MaxHeight="220" Margin="0,0,0,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                    <ui:Button Grid.Column="1" Content="Remove" Tag="{Binding}"
                                               Click="OnRemoveStagedHost" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ui:TextBlock x:Name="StagedHostsEmpty" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                  Margin="0,0,0,8" Visibility="Collapsed"
                                  Text="No machines flagged for staged patching yet." />

                    <ui:Button Content="Clear all" Click="OnClearStagedHosts"
                               ToolTip="Remove every machine from the staged-patching list." />
                </StackPanel>
            </ui:CardExpander>

            <!-- ── Help &amp; about (collapsed expander) ─────────────────── -->
            <ui:CardExpander Margin="0,0,0,8" IsExpanded="False"
                             Icon="{ui:SymbolIcon Info24}"
                             Header="Help &amp; about">
                <StackPanel Margin="0,8,0,0">
                    <ui:TextBlock x:Name="VersionText" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="How to use Vivre…" Icon="{ui:SymbolIcon QuestionCircle24}"
                                   Click="OnOpenHelp"
                                   ToolTip="Open the in-app how-to guide (F1)." />
                        <ui:Button Content="About Vivre…" Icon="{ui:SymbolIcon Info24}"
                                   Margin="8,0,0,0"
                                   Click="OnOpenAbout"
                                   ToolTip="Version, licence, and credits." />
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
