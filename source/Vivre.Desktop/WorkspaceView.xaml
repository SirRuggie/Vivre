<UserControl x:Class="Vivre.Desktop.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Vivre.Desktop"
             xmlns:vm="clr-namespace:Vivre.Desktop.ViewModels"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:StatusBrushConverter x:Key="StatusBrush" />
        <local:StatusSymbolConverter x:Key="StatusSymbol" />
        <local:BoolStateTextConverter x:Key="YesNo" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
        <local:PhaseChipLabelConverter x:Key="PhaseLabel" />
        <local:NotNullToVisibilityConverter x:Key="NotNullToVis" />
        <local:EnumEqualsConverter x:Key="EnumEquals" />
        <local:StringToVisibilityConverter x:Key="StringToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- GridRowStyle: BasedOn Wpf.Ui's KEYED DefaultDataGridRowStyle (not {x:Type DataGridRow}
             which falls through to WPF Aero2 — theme-blind SystemColors near-black text invisible on
             dark background). Adds 36px min-height only; all theme-aware colours come from the base.
             GridColumnHeaderStyle: custom ControlTemplate so Background, bottom separator, sort arrow,
             and hover states are fully owned here — no dependency on Wpf.Ui template internals.
             ControlFillColorDefaultBrush gives a clearly elevated card-style header band in both themes
             (same brush the filter chips use), and DividerStrokeColorDefaultBrush draws the separator
             line between the header band and the first data row. -->
        <Style x:Key="GridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource DefaultDataGridRowStyle}">
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="GridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <!-- Header fill band -->
                            <Border x:Name="Bd"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    <!-- Two separate glyphs — RotateTransform names inside Path.RenderTransform
                                         are not reachable by template triggers, so use one path per direction. -->
                                    <Grid Grid.Column="1">
                                        <Path x:Name="SortArrowAsc"
                                              Visibility="Collapsed"
                                              Width="7" Height="5"
                                              Margin="4,0,4,0"
                                              VerticalAlignment="Center"
                                              Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                              Stretch="Fill"
                                              Data="M0,4 L3.5,0 L7,4 Z" />
                                        <Path x:Name="SortArrowDesc"
                                              Visibility="Collapsed"
                                              Width="7" Height="5"
                                              Margin="4,0,4,0"
                                              VerticalAlignment="Center"
                                              Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                              Stretch="Fill"
                                              Data="M0,0 L3.5,4 L7,0 Z" />
                                    </Grid>
                                </Grid>
                            </Border>
                            <!-- 1px separator line between header band and first data row -->
                            <Border VerticalAlignment="Bottom"
                                    Height="1"
                                    Background="{DynamicResource DividerStrokeColorDefaultBrush}" />
                            <!-- Column resize grippers (named parts required by DataGrid) -->
                            <Thumb x:Name="PART_LeftHeaderGripper"
                                   HorizontalAlignment="Left"
                                   Width="8" Cursor="SizeWE">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                            <Thumb x:Name="PART_RightHeaderGripper"
                                   HorizontalAlignment="Right"
                                   Width="8" Cursor="SizeWE">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrowAsc" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrowDesc" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Item 3: shared vitals pill cell template — used by BOTH the Health grid (ComputerGrid)
             and the Patching grid (UpdateGrid).  Both grids bind the same Computer rows; the vitals
             sweep already fills VitalityScore/Band/Reasons, so no new probing is needed.
             Extracting into one shared resource prevents the template drifting out of sync between
             the two grids (it already drifted once when the Health grid was updated and the Patching
             grid was missed). -->
        <DataTemplate x:Key="VitalsPillCellTemplate">
            <!-- 0-100 vitality score, coloured by band. DataTriggers + DynamicResource
                 so colors re-resolve on theme switch. Hidden until scored. -->
            <Border CornerRadius="8" Padding="8,1" Margin="6,2" HorizontalAlignment="Left" MinWidth="26"
                    Visibility="{Binding VitalityBand, Converter={StaticResource NotNullToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VitalityBand}" Value="Healthy">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VitalityBand}" Value="Warning">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VitalityBand}" Value="Critical">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VitalityBand}" Value="Offline">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <!-- Tooltip is the "why": the scored reasons (worst first) over the raw digest.
                     Right-click ▸ Details… ▸ Vitals shows the full breakdown. -->
                <Border.ToolTip>
                    <ToolTip>
                        <StackPanel MaxWidth="340">
                            <TextBlock Text="{Binding VitalsSummary}" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Visibility="{Binding VitalsSummary, Converter={StaticResource StringToVis}}" />
                            <ItemsControl ItemsSource="{Binding VitalityReasons}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat='• {0}'}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Right-click ▸ Details… ▸ Vitals for the full breakdown."
                                       FontSize="11" Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </ToolTip>
                </Border.ToolTip>
                <TextBlock Text="{Binding VitalityScore, TargetNullValue=—}"
                           HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VitalityBand}" Value="Healthy">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding VitalityBand}" Value="Warning">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding VitalityBand}" Value="Critical">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- A filter "chip": a pill-shaped ToggleButton themed with the app's Fluent brushes — subtle
             fill by default, accent fill + light text when active. Checked state binds to ActiveFilter
             via the enum⇄bool converter, so the chips behave as one radio group. -->
        <Style x:Key="FilterChip" TargetType="ToggleButton">
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chip" CornerRadius="14" Padding="12,7"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filter bar: name search + quick state chips + "select shown" + count.
             Applies to whichever grid is visible (both share the Computers view). Mode is fixed
             by the active Fleet section (Health = machine view, Patching = Windows Update view).
             The filter sub-row is hidden until the tab has machines. -->
        <Grid Grid.Row="0" Margin="12,4,12,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Mode chips removed: tab mode is now fixed by the Fleet section (Health = Machines view,
                 Patching = Windows Update view). Navigate to Fleet ▸ Health or Fleet ▸ Patching
                 in the left nav, or use Ctrl+M to toggle between them. -->

            <!-- Filter sub-row: hidden until the tab has machines. -->
            <Grid Grid.Row="1" Margin="0,0,0,4"
                  Visibility="{Binding HasComputers, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox Grid.Column="0" Width="220" VerticalAlignment="Center"
                            Icon="{ui:SymbolIcon Search24}"
                            ClearButtonEnabled="True"
                            PlaceholderText="Filter by name…"
                            Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                <ToggleButton Style="{StaticResource FilterChip}" Margin="0"
                              Tag="{x:Static vm:RowFilter.All}"
                              Unchecked="OnFilterChipUnchecked"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.All}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="SelectAllOn24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="All" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.UpdatesAvailable}"
                              Unchecked="OnFilterChipUnchecked"
                              ToolTip="Machines with updates available to install"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.UpdatesAvailable}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Updates" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.RebootPending}"
                              Unchecked="OnFilterChipUnchecked"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.RebootPending}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Reboot pending" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.Errors}"
                              Unchecked="OnFilterChipUnchecked"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.Errors}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Errors" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.Offline}"
                              Unchecked="OnFilterChipUnchecked"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.Offline}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PlugDisconnected24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Offline" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.Done}"
                              Unchecked="OnFilterChipUnchecked"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.Done}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Done" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Style="{StaticResource FilterChip}"
                              Tag="{x:Static vm:RowFilter.Unhealthy}"
                              Unchecked="OnFilterChipUnchecked"
                              ToolTip="Machines whose vitality is Warning, Critical, or Offline (run Check Vitals first)"
                              IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumEquals}, ConverterParameter={x:Static vm:RowFilter.Unhealthy}, Mode=TwoWay}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="HeartPulse24" FontSize="14" Margin="0,0,5,0"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Unhealthy" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding FilterStatus}"
                           Visibility="{Binding FilterStatus, Converter={StaticResource StringToVis}}" />
            </StackPanel>

            <ui:Button Grid.Column="2" VerticalAlignment="Center"
                       Icon="{ui:SymbolIcon CheckboxChecked24}" Content="Select shown"
                       Click="OnSelectShown"
                       ToolTip="Select every row currently shown by the filter, so you can act on just that subset (e.g. filter to Errors, Select shown, then Install)." />
            </Grid><!-- end filter sub-row Grid -->
        </Grid><!-- end outer filter bar Grid -->

        <!-- P: amber "Checking vitals" banner — Row 1 (the now-empty layout band between filter and grids).
             WinUI InfoBar style: takes its own slim height while visible, collapses when done.
             Bound to IsVitalsSweepRunning; grid stays fully interactive while it shows. -->
        <Border Grid.Row="1"
                Margin="12,0,12,4"
                Padding="10,6"
                CornerRadius="4"
                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCautionBrush}"
                BorderThickness="1"
                Visibility="{Binding IsVitalsSweepRunning, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Margin="0,0,8,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                <TextBlock VerticalAlignment="Center" FontSize="12" TextWrapping="NoWrap"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Text="{Binding SweepStatus}" />
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="6,0,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="— Scan &amp; Install resume when finished" />
            </StackPanel>
        </Border>

        <!-- Machines grid + update grid + the M13/M29 empty-state overlay are all siblings in root
             row 2 (deliberately NOT wrapped in an intermediate Grid: wrapping made the DataGrid report
             its full multi-column width up the tree, so the whole area grew past the viewport and the
             centred empty-state card landed far off to the right). The DataGrid keeps its own horizontal
             scroll; the overlay is the last sibling (ZIndex 5) so it paints on top, and its panels are
             IsHitTestVisible=False where they have no buttons. -->
        <ui:DataGrid x:Name="ComputerGrid"
                     Grid.Row="2"
                     Visibility="{Binding ShowMachineGrid, Converter={StaticResource BoolToVis}}"
                     ItemsSource="{Binding Computers}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     GridLinesVisibility="Horizontal"
                     HorizontalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                     HeadersVisibility="Column"
                     RowStyle="{StaticResource GridRowStyle}"
                     ColumnHeaderStyle="{StaticResource GridColumnHeaderStyle}"
                     SelectionMode="Extended"
                     SelectionUnit="FullRow"
                     ClipboardCopyMode="IncludeHeader"
                     SelectionChanged="OnGridSelectionChanged"
                     MouseDoubleClick="OnRowDoubleClick"
                     MouseLeftButtonDown="OnGridEmptyAreaClick"
                     PreviewMouseRightButtonDown="OnGridRightClick"
                     PreviewKeyDown="OnGridKeyDown">
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" MinWidth="120" />
                <DataGridTemplateColumn Header="Online" Width="Auto" SortMemberPath="IsOnline">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding IsOnline, Converter={StaticResource StatusSymbol}}"
                                           Foreground="{Binding IsOnline, Converter={StaticResource StatusBrush}}"
                                           ToolTip="{Binding LastStatus}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Vitals" Width="Auto" MinWidth="64" SortMemberPath="VitalityScore"
                                        CellTemplate="{StaticResource VitalsPillCellTemplate}" />
                <DataGridTextColumn Header="Command result" Binding="{Binding CommandResult}" Width="Auto" MinWidth="140" MaxWidth="500">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding CommandResult}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Software check (right-click ▸ Check software…): shows the matched product + version,
                     or "<query> — not found" in red. Blank until a check is run for the row. -->
                <DataGridTextColumn Header="Software" Binding="{Binding SoftwareCheck}" Width="Auto" MinWidth="120" MaxWidth="320" SortMemberPath="SoftwareCheck">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding SoftwareCheck}" />
                            <Style.Triggers>
                                <!-- Found = green, missing = red; "installed but service not running" overrides to amber. -->
                                <DataTrigger Binding="{Binding SoftwareFound}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SoftwareFound}" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SoftwareServiceDown}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Site code" Binding="{Binding SiteCode}" Width="Auto" MinWidth="80" />
                <DataGridTextColumn Header="Agent version" Binding="{Binding AgentVersion}" Width="Auto" MinWidth="100" />
                <DataGridTextColumn Header="Last reboot" Binding="{Binding LastRebootDisplay}" Width="Auto" MinWidth="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding LastBootTime}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RebootRequired">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Reboot" /><LineBreak /><Run Text="Pending" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding RebootRequired, Converter={StaticResource StatusSymbol}, ConverterParameter=problem}"
                                           Foreground="{Binding RebootRequired, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                           ToolTip="{Binding RebootRequired, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="MissingUpdates">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Updates" /><LineBreak /><Run Text="Missing" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding MissingUpdates, Converter={StaticResource StatusSymbol}, ConverterParameter=problem}"
                                           Foreground="{Binding MissingUpdates, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                           ToolTip="{Binding MissingUpdates, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RunningUpdates">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Install" /><LineBreak /><Run Text="Running" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding RunningUpdates, Converter={StaticResource StatusSymbol}, ConverterParameter=problem}"
                                           Foreground="{Binding RunningUpdates, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                           ToolTip="{Binding RunningUpdates, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="UserLoggedOn">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Users" /><LineBreak /><Run Text="Online" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding UserLoggedOn, Converter={StaticResource StatusSymbol}, ConverterParameter=problem}"
                                           Foreground="{Binding UserLoggedOn, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                           ToolTip="{Binding UserLoggedOn, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- M10: per-row error glyph — shown only when LastError is set; moved left of "Last status"
                     so it's visible at 1360px wide. DismissCircle in SystemFillColorCriticalBrush (red)
                     keeps color+shape consistent with the other status-symbol columns. -->
                <DataGridTemplateColumn Header="Last error" Width="Auto" MinWidth="180" MaxWidth="480" SortMemberPath="LastError">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding LastError, Converter={StaticResource StringToVis}}">
                                <ui:SymbolIcon Symbol="DismissCircle24" FontSize="14" Margin="6,0,4,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="{Binding LastError}" FontSize="12"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           MaxWidth="400"
                                           ToolTip="{Binding LastError}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Last status" Binding="{Binding LastStatus}" Width="Auto" MinWidth="160" MaxWidth="400" />
            </ui:DataGrid.Columns>
        </ui:DataGrid>

        <!-- Windows Update view (update mode): the machine grid. The per-machine update detail now
             lives in the shell-level bottom dock (MainWindow), opened when a row is focused. -->
        <Grid Grid.Row="2" Visibility="{Binding ShowUpdateGrid, Converter={StaticResource BoolToVis}}">
            <DockPanel>
            <!-- First-run hint: shown until any machine has been scanned in this tab. -->
            <Border DockPanel.Dock="Top" Margin="0,0,0,6" Padding="10,6" CornerRadius="4"
                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                    Visibility="{Binding ShowUpdateFirstRunHint, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Lightbulb24" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="Select machines and click Scan (selected or all), or click a machine to open its panel and scan just it. Status appears here per machine." />
                </StackPanel>
            </Border>
            <ui:DataGrid x:Name="UpdateGrid"
                     ItemsSource="{Binding Computers}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     GridLinesVisibility="Horizontal"
                     HorizontalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                     RowStyle="{StaticResource GridRowStyle}"
                     ColumnHeaderStyle="{StaticResource GridColumnHeaderStyle}"
                     HeadersVisibility="Column"
                     SelectionMode="Extended"
                     SelectionUnit="FullRow"
                     ClipboardCopyMode="IncludeHeader"
                     SelectionChanged="OnGridSelectionChanged"
                     MouseDoubleClick="OnRowDoubleClick"
                     MouseLeftButtonDown="OnGridEmptyAreaClick"
                     PreviewMouseRightButtonDown="OnGridRightClick"
                     PreviewMouseLeftButtonUp="OnUpdateGridLeftClick"
                     PreviewKeyDown="OnGridKeyDown">
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" MinWidth="120" />
                <DataGridTemplateColumn Header="Ping" Width="Auto" SortMemberPath="IsOnline">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding IsOnline, Converter={StaticResource StatusSymbol}}"
                                           Foreground="{Binding IsOnline, Converter={StaticResource StatusBrush}}"
                                           ToolTip="{Binding LastStatus}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Item 3: vitals pill — same rows as the Health grid; the vitals sweep already fills
                     VitalityScore/Band/Reasons, so this is a display-only addition with no new probing. -->
                <DataGridTemplateColumn Header="Vitals" Width="Auto" MinWidth="64" SortMemberPath="VitalityScore"
                                        CellTemplate="{StaticResource VitalsPillCellTemplate}" />
                <DataGridTemplateColumn Header="Status" Width="Auto" MinWidth="110" SortMemberPath="PatchState">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Colored pill: glanceable per-machine state.
                                 DataTriggers + DynamicResource so colors re-resolve on theme switch. -->
                            <Border CornerRadius="8" Padding="8,1" Margin="6,2" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutralBackgroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Scanning">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Downloading">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Installing">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Uninstalling">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBackgroundBrush}" />
                                            </DataTrigger>
                                            <!-- Available = call-to-action (updates ready to install): accent fill so it
                                                 pops past the quiet working/idle tints. -->
                                            <DataTrigger Binding="{Binding PatchState}" Value="Available">
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="RebootPending">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Done">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PatchState}" Value="Error">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding PatchState, Converter={StaticResource PhaseLabel}}"
                                           FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Scanning">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Downloading">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Installing">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Uninstalling">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Available">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="RebootPending">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Done">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PatchState}" Value="Error">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Reboot message" Binding="{Binding RebootMessage}" Width="Auto" MinWidth="100" MaxWidth="350">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <!-- Right gutter so the trimmed text never butts into the next column. -->
                            <Setter Property="Padding" Value="0,0,16,0" />
                            <Setter Property="ToolTip" Value="{Binding RebootMessage}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Windows update message" Binding="{Binding UpdateMessage}" Width="Auto" MinWidth="180" MaxWidth="500">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="Padding" Value="0,0,16,0" />
                            <Setter Property="ToolTip" Value="{Binding UpdateMessage}" />
                            <!-- Colour the message by state (red error / green done / amber reboot / blue working).
                                 DataTriggers + DynamicResource so colors re-resolve on theme switch. -->
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PatchState}" Value="Scanning">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Downloading">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Installing">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Uninstalling">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Available">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="RebootPending">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Done">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Error">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Progress" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="8,0">
                                <!-- Determinate bar + % for Downloading/Installing. -->
                                <Grid x:Name="BarHost" Visibility="Collapsed">
                                    <ProgressBar Height="14" Minimum="0" Maximum="100"
                                                 Value="{Binding UpdateProgress, FallbackValue=0, TargetNullValue=0}" />
                                    <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0}%}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <!-- Indeterminate marquee while scanning (no % yet). -->
                                <ProgressBar x:Name="Marquee" Height="14" IsIndeterminate="True" Visibility="Collapsed" />
                                <!-- Terminal glyphs: DoneGlyph uses success color, ErrGlyph uses critical.
                                     DynamicResource re-resolves on theme switch. -->
                                <TextBlock x:Name="DoneGlyph" Text="&#x2713;" FontWeight="Bold" Visibility="Collapsed"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <TextBlock x:Name="ErrGlyph" Text="&#x2716;" FontWeight="Bold" Visibility="Collapsed"
                                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding PatchState}" Value="Downloading">
                                    <Setter TargetName="BarHost" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Installing">
                                    <Setter TargetName="BarHost" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Scanning">
                                    <Setter TargetName="Marquee" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Done">
                                    <Setter TargetName="DoneGlyph" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PatchState}" Value="Error">
                                    <Setter TargetName="ErrGlyph" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <!-- Idle / Available / RebootPending: nothing (no misleading 0% bar). -->
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Scheduled task action" Binding="{Binding ScheduledAction}" Width="Auto" MinWidth="80" />
                <DataGridTextColumn Header="Scheduled task next run time" Binding="{Binding ScheduledNextRun, StringFormat=g}" Width="Auto" MinWidth="80" />
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RebootRequired">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Pending" /><LineBreak /><Run Text="Reboot" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:SymbolIcon Margin="8,0" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Symbol="{Binding RebootRequired, Converter={StaticResource StatusSymbol}, ConverterParameter=problem}"
                                           Foreground="{Binding RebootRequired, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                           ToolTip="{Binding RebootRequired, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Command result (e.g. output of a Run Script / "Restart - force now") — shown here too,
                     since scripts are commonly run from the Patching (Windows Update) section. -->
                <DataGridTextColumn Header="Command messages" Binding="{Binding CommandResult}" Width="Auto" MinWidth="140" MaxWidth="500">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding CommandResult}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </ui:DataGrid.Columns>
            </ui:DataGrid>
            </DockPanel>
        </Grid>

        <!-- M13/M29: mutually-exclusive overlays over the grid area.
             Precedence (GridOverlayState):
               2 = cold start   → M29 "Get started" card
               3 = filter-empty → M13 simple "No matches" state
               0 = data present → no overlay (panels collapsed) -->
        <!-- Empty-state overlay, anchored TOP-LEFT with an inset. Centering was re-attempted (Round 2) but
             the card drifts right at wider widths: with the grid collapsed there's no ScrollViewer bounding
             the row, and the DataGrid's column width still leaks into the shared Row-2 cell, so a centred
             child centres within a too-wide area and slides off to the right. Top-left is overflow-proof and
             consistent at any window size. Not hit-test-blocking: the visible state's buttons handle their
             own input; collapsed siblings don't steal it. -->
        <Grid Grid.Row="2" Panel.ZIndex="5">

            <!-- State 2 — M29: cold-start "Get started" card (GitHub Desktop style). -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,56,0,0"
                    MaxWidth="460"
                    CornerRadius="8" Padding="32,24"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding GridOverlayState}" Value="2">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Get started" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <!-- Row 1: Paste machine names -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                            <ui:SymbolIcon Symbol="ClipboardPaste24" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Paste machine names" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Click the Paste button above or use the text box" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Row 2: Ping / Check Vitals -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                            <ui:SymbolIcon Symbol="Pulse24" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ping / Check Vitals" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Use the toolbar to ping machines and pull health scores" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <!-- Row 3: Health / Patching nav -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                            <ui:SymbolIcon Symbol="ArrowSwap24" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Switch section" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Use Fleet ▸ Health / Patching in the nav, or Ctrl+M" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <!-- "Open help" link — wired to the same F1 / Help ▸ How to use Vivre command. -->
                    <ui:Button HorizontalAlignment="Center" Appearance="Secondary"
                               Icon="{ui:SymbolIcon QuestionCircle24}" Content="Open help (F1)"
                               Click="OnGetStartedHelp"
                               ToolTip="Open the How to use Vivre guide" />
                </StackPanel>
            </Border>

            <!-- State 3 — M13: filter-empty state (has a clickable button so IsHitTestVisible stays True). -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,56,0,0" Orientation="Vertical">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding GridOverlayState}" Value="3">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="Filter24" FontSize="36" HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <TextBlock Style="{StaticResource EmptyStateTitle}"
                           Text="No machines match this filter" />
                <TextBlock Style="{StaticResource EmptyStateSubtitle}"
                           Text="Try clearing the filter or switching to All" />
                <!-- Clear-filter affordance. -->
                <ui:Button Margin="0,12,0,0" HorizontalAlignment="Center" Appearance="Secondary"
                           Icon="{ui:SymbolIcon Dismiss24}" Content="Clear filter"
                           Click="OnClearFilter"
                           ToolTip="Reset to All and clear the name filter" />
            </StackPanel>

        </Grid><!-- end overlay Grid -->
    </Grid>
</UserControl>
