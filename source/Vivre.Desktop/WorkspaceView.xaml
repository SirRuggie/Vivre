<UserControl x:Class="Vivre.Desktop.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Vivre.Desktop"
             mc:Ignorable="d">

    <UserControl.Resources>
        <local:StatusBrushConverter x:Key="StatusBrush" />
        <local:BoolStateTextConverter x:Key="YesNo" />
        <local:UpdateSourceNameConverter x:Key="UpdateSourceName" />
        <local:InverseBooleanConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Two RadioButtons styled as a segmented pill for the Machines / Windows Update switch. -->
        <Style x:Key="SegmentRadio" TargetType="RadioButton">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Mode switch (segmented) + (in Windows Update mode) the patch command bar. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,4,12,8" VerticalAlignment="Center">
            <Border CornerRadius="6" BorderThickness="1" Padding="2"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    VerticalAlignment="Center"
                    ToolTip="Switch this tab between the Machines view and the Windows Update view (same machine list).">
                <StackPanel Orientation="Horizontal">
                    <RadioButton GroupName="ViewMode" Style="{StaticResource SegmentRadio}" Content="Machines"
                                 IsChecked="{Binding IsUpdateMode, Converter={StaticResource InverseBool}, Mode=TwoWay}" />
                    <RadioButton GroupName="ViewMode" Style="{StaticResource SegmentRadio}" Content="Windows Update"
                                 IsChecked="{Binding IsUpdateMode, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Patch command bar — visible only in Windows Update mode. -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Source:" VerticalAlignment="Center" Margin="16,0,6,0" />
                <ComboBox Width="160" VerticalAlignment="Center"
                          ItemsSource="{Binding UpdateSources}"
                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                          ToolTip="Windows Update = OS/drivers; Microsoft Update adds SQL/Office/.NET; Managed = WSUS/SCCM.">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource UpdateSourceName}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:TextBox Width="200" Margin="12,0,0,0" VerticalAlignment="Center"
                            PlaceholderText="Exclude titles (e.g. SQL, Silverlight)"
                            Text="{Binding ExcludeText, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Margin="12,0,0,0" VerticalAlignment="Center" Content="Include drivers"
                          IsChecked="{Binding IncludeDrivers, Mode=TwoWay}"
                          ToolTip="Off (default) hides driver updates from scan/install (Type='Software') — matches the Windows Update UI and BatchPatch. Turn on to also see and install drivers." />
                <ui:Button Margin="12,0,0,0" Icon="{ui:SymbolIcon Search24}" Content="Scan"
                           Command="{Binding ScanUpdatesCommand}" />
                <ui:Button Margin="8,0,0,0" Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Install"
                           Command="{Binding InstallUpdatesCommand}"
                           ToolTip="Download + install all applicable updates (one-time SYSTEM task per host). Reboot is reported, not forced." />
            </StackPanel>
        </StackPanel>

        <!-- Machines grid (default mode). -->
        <ui:DataGrid x:Name="ComputerGrid"
                     Grid.Row="1"
                     Visibility="{Binding IsMachineMode, Converter={StaticResource BoolToVis}}"
                     ItemsSource="{Binding Computers}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     GridLinesVisibility="Horizontal"
                     HeadersVisibility="Column"
                     SelectionMode="Extended"
                     SelectionUnit="FullRow"
                     ClipboardCopyMode="IncludeHeader"
                     SelectionChanged="OnGridSelectionChanged"
                     MouseDoubleClick="OnRowDoubleClick"
                     PreviewMouseRightButtonDown="OnGridRightClick"
                     PreviewKeyDown="OnGridKeyDown">
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" />
                <DataGridTemplateColumn Header="Online" Width="Auto" SortMemberPath="IsOnline">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding IsOnline, Converter={StaticResource StatusBrush}}"
                                     ToolTip="{Binding LastStatus}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Command result" Binding="{Binding CommandResult}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding CommandResult}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Site code" Binding="{Binding SiteCode}" Width="Auto" />
                <DataGridTextColumn Header="Agent version" Binding="{Binding AgentVersion}" Width="Auto" />
                <DataGridTextColumn Header="Last reboot" Binding="{Binding LastRebootDisplay}" Width="Auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="ToolTip" Value="{Binding LastBootTime}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RebootRequired">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Reboot" /><LineBreak /><Run Text="Pending" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding RebootRequired, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                     ToolTip="{Binding RebootRequired, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="MissingUpdates">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Updates" /><LineBreak /><Run Text="Missing" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding MissingUpdates, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                     ToolTip="{Binding MissingUpdates, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RunningUpdates">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Install" /><LineBreak /><Run Text="Running" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding RunningUpdates, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                     ToolTip="{Binding RunningUpdates, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto" SortMemberPath="UserLoggedOn">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Users" /><LineBreak /><Run Text="Online" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding UserLoggedOn, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                     ToolTip="{Binding UserLoggedOn, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Last status" Binding="{Binding LastStatus}" Width="2*" />
                <DataGridTextColumn Header="Last error" Binding="{Binding LastError}" Width="2*" />
            </ui:DataGrid.Columns>
        </ui:DataGrid>

        <!-- Windows Update view (update mode): machine grid (left) + per-machine update checklist (right). -->
        <Grid Grid.Row="1" Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="360" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <ui:DataGrid x:Name="UpdateGrid"
                     Grid.Column="0"
                     ItemsSource="{Binding Computers}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     CanUserAddRows="False"
                     CanUserDeleteRows="False"
                     GridLinesVisibility="Horizontal"
                     HeadersVisibility="Column"
                     SelectionMode="Extended"
                     SelectionUnit="FullRow"
                     ClipboardCopyMode="IncludeHeader"
                     SelectionChanged="OnGridSelectionChanged"
                     PreviewMouseRightButtonDown="OnGridRightClick"
                     PreviewKeyDown="OnGridKeyDown">
            <ui:DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" />
                <DataGridTemplateColumn Header="Ping" Width="Auto" SortMemberPath="IsOnline">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding IsOnline, Converter={StaticResource StatusBrush}}"
                                     ToolTip="{Binding LastStatus}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Reboot message" Binding="{Binding RebootMessage}" Width="1.2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding RebootMessage}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Windows update message" Binding="{Binding UpdateMessage}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding UpdateMessage}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Progress" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="8,0">
                                <ProgressBar Height="14" Minimum="0" Maximum="100" Value="{Binding UpdateProgress, FallbackValue=0, TargetNullValue=0}" />
                                <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0}%}" FontSize="10"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Scheduled task action" Binding="{Binding ScheduledAction}" Width="Auto" />
                <DataGridTextColumn Header="Scheduled task next run time" Binding="{Binding ScheduledNextRun}" Width="Auto" />
                <DataGridTemplateColumn Width="Auto" SortMemberPath="RebootRequired">
                    <DataGridTemplateColumn.Header>
                        <TextBlock TextAlignment="Center"><Run Text="Pending" /><LineBreak /><Run Text="Reboot" /></TextBlock>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Margin="10,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{Binding RebootRequired, Converter={StaticResource StatusBrush}, ConverterParameter=problem}"
                                     ToolTip="{Binding RebootRequired, Converter={StaticResource YesNo}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Command messages" Binding="{Binding CommandResult}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="ToolTip" Value="{Binding CommandResult}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </ui:DataGrid.Columns>
            </ui:DataGrid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Background="Transparent" />

            <!-- Per-machine update checklist for the focused row. -->
            <Border Grid.Column="2" Padding="10,0,0,0" BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
                <Grid>
                    <TextBlock Text="Select a machine on the left to see and choose its updates."
                               TextWrapping="Wrap" TextAlignment="Center" Margin="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FocusedComputer}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DockPanel>
                        <DockPanel.Style>
                            <Style TargetType="DockPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FocusedComputer}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DockPanel.Style>

                        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,8">
                            <TextBlock Text="{Binding FocusedComputer.Name}" FontWeight="SemiBold" FontSize="14"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12">
                                <Run Text="{Binding FocusedComputer.ScannedUpdates.Count, Mode=OneWay}" /><Run Text=" update(s) — tick to install" />
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ui:Button Content="All" Appearance="Secondary" Padding="10,2" Command="{Binding SelectAllUpdatesCommand}" />
                                <ui:Button Content="None" Appearance="Secondary" Padding="10,2" Margin="6,0,0,0" Command="{Binding SelectNoUpdatesCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <ui:Button DockPanel.Dock="Bottom" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                   Appearance="Primary" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Install checked"
                                   Command="{Binding InstallCheckedCommand}"
                                   ToolTip="Install only the ticked updates on this machine (one-time SYSTEM task). Reboot is reported, not forced." />

                        <ui:DataGrid ItemsSource="{Binding FocusedComputer.ScannedUpdates}"
                                     AutoGenerateColumns="False" IsReadOnly="True"
                                     CanUserAddRows="False" CanUserDeleteRows="False"
                                     HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                     SelectionMode="Single" SelectionUnit="FullRow">
                            <ui:DataGrid.Columns>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="KB" Binding="{Binding Kb}" Width="Auto" />
                                <DataGridTextColumn Header="Update" Binding="{Binding Title}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="ToolTip" Value="{Binding Title}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Size" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="Auto" />
                            </ui:DataGrid.Columns>
                        </ui:DataGrid>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
